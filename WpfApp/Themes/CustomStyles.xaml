<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- ============================================================ -->
    <!-- DESIGN SYSTEM TOKENS (Dd* prefix)                             -->
    <!-- Source of truth: design-system/colors_and_type.css            -->
    <!-- Mapping reference: design-system/MAPPING.md                   -->
    <!-- Do NOT add ad-hoc colors here. New tokens go to CSS first.    -->
    <!-- ============================================================ -->

    <!-- Backgrounds (glass backdrop) -->
    <SolidColorBrush x:Key="DdBgBase"     Color="#FF0A1520"/>
    <!-- Outer pane: near-opaque. DdSurface1 (5% white) and DdBgSidebar layer
         on top of this, so if the outer is too transparent the desktop
         bleeds through everything. ~3% transparency keeps a hint of glass
         for the rounded edge without looking choppy over busy backgrounds. -->
    <SolidColorBrush x:Key="DdBgGlass"    Color="#F70A1520"/>
    <!-- Sidebar tint overlays DdBgGlass. Mostly-opaque so the sidebar
         reads as its own surface rather than a translucent layer picking
         up whatever's behind the window. -->
    <SolidColorBrush x:Key="DdBgSidebar"  Color="#F0050C16"/>
    <SolidColorBrush x:Key="DdBgHeader"   Color="#4F000000"/>
    <SolidColorBrush x:Key="DdBgOverlay"  Color="#80000000"/>

    <!-- Surfaces (white-on-glass) -->
    <SolidColorBrush x:Key="DdSurface1"   Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="DdSurface2"   Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="DdSurface3"   Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="DdSurfaceRow" Color="#0FFFFFFF"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="DdBorderThin"   Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="DdBorderMed"    Color="#2EFFFFFF"/>
    <SolidColorBrush x:Key="DdBorderStrong" Color="#47FFFFFF"/>

    <!-- Text -->
    <SolidColorBrush x:Key="DdFg1"         Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="DdFg2"         Color="#A6FFFFFF"/>
    <SolidColorBrush x:Key="DdFg3"         Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="DdFgOnAccent"  Color="#FF1A0A02"/>

    <!-- Brand accent (deep purple, user-spec #6C419A 2026-05-27).
         Hi/Lo derived in HSL (±15% lightness) so gradient + glow stay
         coherent. Soft is the base at 22% alpha — same alpha as before. -->
    <SolidColorBrush x:Key="DdAccent"     Color="#FF6C419A"/>
    <SolidColorBrush x:Key="DdAccentHi"   Color="#FF8C64BC"/>
    <SolidColorBrush x:Key="DdAccentLo"   Color="#FF4C2E6C"/>
    <SolidColorBrush x:Key="DdAccentSoft" Color="#386C419A"/>

    <!-- Brand accent gradient (vertical: hi → mid → lo) -->
    <LinearGradientBrush x:Key="DdAccentGrad" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF8C64BC" Offset="0.00"/>
        <GradientStop Color="#FF6C419A" Offset="0.55"/>
        <GradientStop Color="#FF4C2E6C" Offset="1.00"/>
    </LinearGradientBrush>

    <!-- Secondary accent (Material Indigo) -->
    <SolidColorBrush x:Key="DdInfo"     Color="#FF7986CB"/>
    <SolidColorBrush x:Key="DdInfoSoft" Color="#337986CB"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="DdSuccess"     Color="#FF23C46A"/>
    <SolidColorBrush x:Key="DdSuccessSoft" Color="#2E23C46A"/>
    <SolidColorBrush x:Key="DdWarn"        Color="#FFFFB547"/>
    <SolidColorBrush x:Key="DdWarnSoft"    Color="#2EFFB547"/>
    <SolidColorBrush x:Key="DdDanger"      Color="#FFFF6B6B"/>
    <SolidColorBrush x:Key="DdDangerSoft"  Color="#29FF6B6B"/>
    <SolidColorBrush x:Key="DdNeutral"     Color="#FF808890"/>

    <!-- Keyboard-view specific (used by plan-2 keyboard view) -->
    <SolidColorBrush x:Key="DdKeyBg"         Color="#08FFFFFF"/>
    <SolidColorBrush x:Key="DdKeyBorder"     Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="DdKeyHover"      Color="#1F6C419A"/>
    <SolidColorBrush x:Key="DdKeySelected"   Color="#426C419A"/>
    <SolidColorBrush x:Key="DdKeyText"       Color="#D9FFFFFF"/>
    <SolidColorBrush x:Key="DdKeyTextDim"    Color="#73FFFFFF"/>
    <SolidColorBrush x:Key="DdActuationLow"  Color="#FF7986CB"/>
    <SolidColorBrush x:Key="DdActuationMid"  Color="#FFB39DDB"/>
    <SolidColorBrush x:Key="DdActuationHigh" Color="#FF9575CD"/>

    <!-- Type scale (in px) -->
    <sys:Double x:Key="DdFsXs">10.5</sys:Double>
    <sys:Double x:Key="DdFsSm">11.5</sys:Double>
    <sys:Double x:Key="DdFsBase">12.5</sys:Double>
    <sys:Double x:Key="DdFsMd">13.5</sys:Double>
    <sys:Double x:Key="DdFsLg">15.5</sys:Double>
    <sys:Double x:Key="DdFsXl">20</sys:Double>
    <sys:Double x:Key="DdFsXxl">26</sys:Double>

    <!-- Font families (Inter not bundled in v1; falls back to Segoe UI Variable) -->
    <FontFamily x:Key="DdFontSans">Inter, Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="DdFontMono">JetBrains Mono, Cascadia Mono, Consolas</FontFamily>

    <!-- Corner radii -->
    <CornerRadius x:Key="DdRadiusXs">4</CornerRadius>
    <CornerRadius x:Key="DdRadiusSm">6</CornerRadius>
    <CornerRadius x:Key="DdRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="DdRadiusLg">10</CornerRadius>
    <CornerRadius x:Key="DdRadiusXl">12</CornerRadius>
    <CornerRadius x:Key="DdRadiusPill">999</CornerRadius>

    <!-- Drop shadows (DropShadowEffect — share between elements via {StaticResource}) -->
    <DropShadowEffect x:Key="DdShadow1"     BlurRadius="2"  ShadowDepth="1"  Opacity="0.30" Color="#000000"/>
    <DropShadowEffect x:Key="DdShadow2"     BlurRadius="14" ShadowDepth="4"  Opacity="0.35" Color="#000000"/>
    <DropShadowEffect x:Key="DdShadow3"     BlurRadius="32" ShadowDepth="12" Opacity="0.45" Color="#000000"/>
    <DropShadowEffect x:Key="DdGlowAccent"  BlurRadius="18" ShadowDepth="0"  Opacity="0.55" Color="#6C419A"/>

    <!-- Motion (used as TimeSpan / EasingFunction in storyboards) -->
    <Duration x:Key="DdDurFast">0:0:0.12</Duration>
    <Duration x:Key="DdDurBase">0:0:0.18</Duration>
    <Duration x:Key="DdDurSlow">0:0:0.26</Duration>
    <CubicEase x:Key="DdEaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="DdEaseInOut" EasingMode="EaseInOut"/>

    <!-- ===== TOOLTIP (opaque, readable on glass windows) ===== -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource DdBgGlass}"/>
        <Setter Property="Foreground" Value="{StaticResource DdFg1}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DdBorderMed}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="{StaticResource DdFsBase}"/>
        <Setter Property="FontFamily" Value="{StaticResource DdFontSans}"/>
        <Setter Property="MaxWidth" Value="320"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DdRadiusMd}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"
                                          MaxWidth="{TemplateBinding MaxWidth}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== GLASS CARD ===== -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DdSurface2}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DdBorderThin}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource DdRadiusLg}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- ===== SIDEBAR PROFILE ITEM ===== -->
    <Style x:Key="GlassListItem" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="6,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DdFg1}"/>
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource DdRadiusMd}"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ===== SIDEBAR BUTTON ===== -->
    <Style x:Key="GlassSidebarBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Foreground" Value="{StaticResource DdFg2}"/>
        <Setter Property="FontFamily" Value="{StaticResource DdFontSans}"/>
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource DdRadiusMd}"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ===== PILL BUTTON ===== -->
    <!-- ButtonAssist.CornerRadius is applied literally (no CSS-style clamping),
         so use 16 to match a ~32px MaterialDesign button height. Border-based
         pill elements (GlassChip) can use 999 because Border CornerRadius does
         clamp. -->
    <Style x:Key="GlassPillBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="{StaticResource DdFsBase}"/>
        <Setter Property="FontFamily" Value="{StaticResource DdFontSans}"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="16"/>
    </Style>

    <!-- ===== SUBTLE BUTTON ===== -->
    <Style x:Key="GlassSubtleBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="FontSize" Value="{StaticResource DdFsBase}"/>
        <Setter Property="FontFamily" Value="{StaticResource DdFontSans}"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Foreground" Value="{StaticResource DdFg2}"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
    </Style>

    <!-- ===== CHIP TOGGLE =====
         Compact rectangular toggle matching the "Sync now" / "Open log folder"
         button shape — slight rounded corners, not full ovals. Purple when on,
         thin outline when off. Replaces MaterialDesignSwitchToggleButton
         everywhere the space pressure outweighed the affordance value. -->
    <Style x:Key="DdChipToggle" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource DdFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource DdFsXs}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource DdFg2}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource DdBorderThin}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource DdRadiusSm}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DdAccent}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DdAccent}"/>
                            <Setter Property="Foreground" Value="{StaticResource DdFg1}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DdAccentSoft}"/>
                            <Setter Property="Foreground" Value="{StaticResource DdFg1}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DdAccentSoft}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== TRIGGER CHIP ===== -->
    <Style x:Key="GlassChip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DdSurfaceRow}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DdBorderThin}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="0,0,6,6"/>
    </Style>

    <!-- ===== DIVIDER ===== -->
    <Style x:Key="GlassDivider" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource DdBorderThin}"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- ===== ICON BUTTON (small, transparent) ===== -->
    <Style x:Key="GlassIconBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignToolButton}">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource DdFg3}"/>
        <Setter Property="Opacity" Value="0"/>
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource DdRadiusSm}"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ===== CONTEXT MENU ===== -->
    <Style x:Key="GlassContextMenu" TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource DdBgGlass}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DdBorderMed}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DdRadiusLg}" Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource DdShadow2}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== CONTEXT MENU ITEM ===== -->
    <Style x:Key="GlassMenuItem" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource DdFg1}"/>
        <Setter Property="FontSize" Value="{StaticResource DdFsBase}"/>
        <Setter Property="FontFamily" Value="{StaticResource DdFontSans}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bg" CornerRadius="{StaticResource DdRadiusSm}" Background="Transparent"
                            Padding="{TemplateBinding Padding}" Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter x:Name="Icon" Content="{TemplateBinding Icon}"
                                              Width="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource DdSurface3}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== DELETE MENU ITEM (red) ===== -->
    <Style x:Key="GlassMenuItemDelete" TargetType="MenuItem" BasedOn="{StaticResource GlassMenuItem}">
        <Setter Property="Foreground" Value="{StaticResource DdDanger}"/>
    </Style>

    <!-- ===== SEGMENTED TAB (RadioButton) =====
         Shared by the inner Performance / Remap tabs inside the keyboard view
         and the new top-level Keyboard / Lighting nav strip. Hoisted from
         KeyboardPerformanceView.xaml's local Grid.Resources so both consumers
         use the same source. DynamicResource keeps the brush bindings live
         across theme reloads. -->
    <Style x:Key="SegmentedTabStyle" TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{DynamicResource DdFontSans}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource DdFg2}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DdBorderThin}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource DdRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DdAccent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DdAccent}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DdAccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== DROPDOWN (ComboBox) =====
         Visual match to the Settings overlay: glass-card popup (DdBgGlass
         + DdRadiusXl + DdShadow3), DdRadiusMd item rows with flat-button
         hover, clean separators between rows. The toggle header uses the
         same outlined surface as a card (DdSurface1 + DdBorderThin) at
         DdRadiusMd. Custom template here is essential — the previous
         "inherit MaterialDesignOutlinedComboBox" approach gave us the
         default M3 popup, not the glass card. -->
    <Style x:Key="DdComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="{DynamicResource DdFontSans}"/>
        <Setter Property="FontSize" Value="{DynamicResource DdFsBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{DynamicResource DdRadiusMd}"
                            Margin="4,1">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DdSurfaceRow}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DdAccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DdComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{DynamicResource DdFontSans}"/>
        <Setter Property="FontSize" Value="{DynamicResource DdFsBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
        <Setter Property="Background" Value="{DynamicResource DdSurface1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DdBorderThin}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="14,7,8,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource DdComboBoxItemStyle}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Header: surface card with selected text + chevron.
                             The selected item is rendered by a single
                             ContentPresenter directly bound to the ComboBox's
                             SelectionBoxItem via RelativeSource — no double
                             ContentControl wrapping (the previous version
                             produced empty / truncated headers). -->
                        <ToggleButton x:Name="HeaderToggle"
                                      Focusable="False"
                                      ClickMode="Press"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Padding="{TemplateBinding Padding}"
                                      MinHeight="{TemplateBinding MinHeight}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      IsChecked="{Binding IsDropDownOpen,
                                                          RelativeSource={RelativeSource TemplatedParent},
                                                          Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="HeaderBd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="{DynamicResource DdRadiusMd}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Content="{Binding SelectionBoxItem,
                                                                                RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              ContentTemplate="{Binding SelectionBoxItemTemplate,
                                                                                RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              IsHitTestVisible="False"
                                                              TextElement.Foreground="{Binding Foreground,
                                                                                RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            <Path Grid.Column="1"
                                                  Width="10" Height="6"
                                                  Margin="10,0,2,0"
                                                  VerticalAlignment="Center"
                                                  Stretch="Uniform"
                                                  Data="M 0,0 L 5,5 L 10,0 Z"
                                                  Fill="{DynamicResource DdFg2}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HeaderBd" Property="BorderBrush"
                                                    Value="{DynamicResource DdAccentSoft}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="HeaderBd" Property="BorderBrush"
                                                    Value="{DynamicResource DdAccent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Focusable="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,6,0,12"
                                    Background="{DynamicResource DdBgGlass}"
                                    BorderBrush="{DynamicResource DdBorderMed}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource DdRadiusXl}"
                                    Effect="{DynamicResource DdShadow3}">
                                <ScrollViewer Margin="6"
                                              SnapsToDevicePixels="True"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== TOGGLE CHIP =====
         Single-button toggle styled like SegmentedTabStyle (which is
         RadioButton-only). Used for binary state buttons that need to
         visually match the rest of the segmented-tab strip — e.g. the
         Custom per-key toggle alongside the effect dropdown. -->
    <Style x:Key="DdToggleChipStyle" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{DynamicResource DdFontSans}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource DdFg2}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DdBorderThin}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource DdRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DdAccent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DdAccent}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DdAccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
