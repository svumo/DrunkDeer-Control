<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Card style with consistent padding and elevation -->
    <Style x:Key="DashboardCard" TargetType="materialDesign:Card">
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
        <Setter Property="UniformCornerRadius" Value="8"/>
    </Style>

    <!-- Section header style (e.g., "PROFILES") -->
    <Style x:Key="SectionHeader" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignOverlineTextBlock}">
        <Setter Property="Margin" Value="16,12,16,8"/>
        <Setter Property="Opacity" Value="0.6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- Card section title (e.g., "Profile Overview") -->
    <Style x:Key="CardSectionTitle" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignSubtitle1TextBlock}">
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Status bar text style -->
    <Style x:Key="StatusBarText" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="12,0"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <!-- Status bar separator -->
    <Style x:Key="StatusBarSeparator" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="4,6"/>
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
        <Setter Property="Opacity" Value="0.3"/>
    </Style>

    <!-- Sidebar profile item container -->
    <Style x:Key="ProfileListItem" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="4,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <!-- Empty state text -->
    <Style x:Key="EmptyStateText" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignBody1TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <!-- Sidebar import button -->
    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="Height" Value="Auto"/>
    </Style>

    <!-- Detail panel action button (Activate) -->
    <Style x:Key="ActionButtonPrimary" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4"/>
    </Style>

    <!-- Detail panel action button (Delete - outlined) -->
    <Style x:Key="ActionButtonDanger" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="Foreground" Value="#EF5350"/>
        <Setter Property="BorderBrush" Value="#EF5350"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4"/>
    </Style>

    <!-- Process trigger chip/tag style -->
    <Style x:Key="TriggerChip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,0,6,6"/>
    </Style>

</ResourceDictionary>
