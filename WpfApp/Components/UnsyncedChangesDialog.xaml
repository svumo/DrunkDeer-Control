<Window x:Class="WpfApp.Components.UnsyncedChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="DrunkDeer Control"
        Icon="/Resources/drunkdeer-control-logo.ico"
        Height="280" Width="500"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Topmost="True"
        ResizeMode="NoResize"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True">

    <Border CornerRadius="{StaticResource DdRadiusXl}" BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
            Background="{StaticResource DdBgGlass}" ClipToBounds="True"
            Effect="{StaticResource DdShadow3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource DdBgHeader}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/drunkdeer-control-logo.png" Width="20" Height="20"
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="UNSYNCED CHANGES" FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                   Foreground="{StaticResource DdFg2}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="28" Height="28" Padding="0" Foreground="{StaticResource DdFg3}">
                        <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Lead -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Name="HeaderTitle" Text="You have unsynced changes"
                               FontSize="{StaticResource DdFsXl}" FontWeight="SemiBold"
                               Foreground="{StaticResource DdFg1}"/>
                    <TextBlock Name="HeaderSubtitle" Text=""
                               FontSize="{StaticResource DdFsBase}" Foreground="{StaticResource DdFg3}"
                               TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- (no detail card — keep this dialog short) -->

                <!-- Actions -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Name="StayButton"
                            Content="Stay on this profile"
                            Click="StayButton_Click"
                            Style="{StaticResource GlassSubtleBtn}" Margin="0,0,8,0"
                            IsCancel="True"/>
                    <Button Grid.Column="2" Name="DiscardButton"
                            Content="Discard and switch"
                            Click="DiscardButton_Click"
                            Style="{StaticResource GlassSubtleBtn}" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Name="PushButton"
                            Content="Push and switch"
                            Click="PushButton_Click"
                            Style="{StaticResource GlassPillBtn}" IsDefault="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
