<UserControl x:Class="WpfApp.Components.KeyboardView.KeyCap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="40"
             Cursor="Hand">
    <Border x:Name="Root"
            Background="{DynamicResource DdKeyBg}"
            BorderBrush="{DynamicResource DdKeyBorder}"
            BorderThickness="1"
            CornerRadius="{DynamicResource DdRadiusSm}"
            Effect="{DynamicResource DdShadow1}">
        <Grid>
            <!-- Three vertical zones, all centered on the cap's horizontal axis:
                   TopText    — AP mm value when customized, otherwise the
                                shift-character (e.g. "~" above the grave). Single
                                slot so they can't overlap.
                   LabelText  — primary character / key name.
                   RtBadge    — "RT" indicator when the key is in Rapid Trigger.
                 Future per-key indicators (e.g. remap binding in Phase H) can
                 land in the corners (top-left / bottom-left) without disturbing
                 this center-axis stack. -->
            <TextBlock x:Name="TopText"
                       FontFamily="{DynamicResource DdFontMono}"
                       FontWeight="Medium"
                       Foreground="{DynamicResource DdKeyTextDim}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       TextAlignment="Center"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>
            <TextBlock x:Name="LabelText"
                       FontFamily="{DynamicResource DdFontSans}"
                       FontWeight="Medium"
                       Foreground="{DynamicResource DdKeyText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock x:Name="RtBadge"
                       Text="RT"
                       FontFamily="{DynamicResource DdFontSans}"
                       FontSize="9"
                       FontWeight="Bold"
                       Foreground="{DynamicResource DdAccentHi}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,3"
                       Visibility="Collapsed"/>
            <Rectangle x:Name="UncertainStripe"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Width="5" Height="5"
                       RadiusX="1" RadiusY="1"
                       Margin="0,4,4,0"
                       Fill="#FFFFAB40"
                       Visibility="Collapsed"
                       ToolTip="Slot mapping not yet verified on hardware"/>
            <!-- Live depth bar (keystroke tracking). Sits at the bottom edge
                 of the cap; DepthFill's Width is proportional to LiveDepth
                 (0 mm → empty, 4 mm → full). Whole stack is collapsed when
                 LiveDepth == 0 so caps in non-tracking mode stay clean. -->
            <Grid x:Name="DepthBar"
                  Height="3"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Stretch"
                  Margin="3,0,3,3"
                  Visibility="Collapsed">
                <Border CornerRadius="{DynamicResource DdRadiusSm}"
                        Background="{DynamicResource DdSurfaceRow}"/>
                <Border x:Name="DepthFill"
                        HorizontalAlignment="Left"
                        CornerRadius="{DynamicResource DdRadiusSm}"
                        Background="{DynamicResource DdAccent}"
                        Width="0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
