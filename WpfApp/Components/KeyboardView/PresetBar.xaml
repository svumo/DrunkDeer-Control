<UserControl x:Class="WpfApp.Components.KeyboardView.PresetBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="56">
    <UserControl.Resources>
        <Style x:Key="PresetButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DdSurface2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DdBorderThin}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource DdFg1}"/>
            <Setter Property="FontFamily" Value="{DynamicResource DdFontSans}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource DdRadiusMd}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DdAccentHi}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Margin="0,0,10,0" Style="{StaticResource PresetButton}" Click="OnPresetClick" Tag="fps">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource DdActuationLow}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="FPS · WASD shallow"/>
                </StackPanel>
            </Button>
            <Button Margin="0,0,10,0" Style="{StaticResource PresetButton}" Click="OnPresetClick" Tag="typing">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource DdActuationHigh}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Typing · uniform deep"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PresetButton}" Click="OnPresetClick" Tag="reset"
                    Content="Reset all to 2.0 mm"/>
        </StackPanel>

        <!-- Live counts on the right -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="CustomizedCount"
                       FontFamily="{DynamicResource DdFontMono}"
                       FontSize="11"
                       Foreground="{DynamicResource DdFg3}"
                       Text="0 customized"
                       VerticalAlignment="Center"
                       Margin="0,0,18,0"/>
            <TextBlock x:Name="RtCount"
                       FontFamily="{DynamicResource DdFontMono}"
                       FontSize="11"
                       Foreground="{DynamicResource DdFg3}"
                       Text="0 in Rapid Trigger"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
