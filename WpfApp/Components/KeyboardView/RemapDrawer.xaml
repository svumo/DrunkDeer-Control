<UserControl x:Class="WpfApp.Components.KeyboardView.RemapDrawer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="360" d:DesignHeight="520"
             Width="360"
             Focusable="True">
    <Border Background="{DynamicResource DdSurface2}"
            BorderBrush="{DynamicResource DdBorderThin}"
            BorderThickness="1,0,0,0"
            VerticalAlignment="Stretch">
        <!-- ScrollViewer needs its parent to give it a bounded height — the
             VerticalAlignment="Stretch" on the Border above ensures that.
             Without it the UserControl sizes to content and overflows the
             window, clipping the bottom buttons. -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch">
            <StackPanel Margin="24,24,24,24">
                <TextBlock Text="REMAP KEY"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource DdFg3}"
                           Margin="0,0,0,6"/>

                <TextBlock x:Name="TitleText"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DdFg1}"
                           Text="No key selected"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="EmptyHint"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="12"
                           Foreground="{DynamicResource DdFg3}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Text="Click a key on the canvas to rebind it. Multi-select to reset many bindings at once."/>

                <!-- Reset-all shortcut — always visible so users can bail out
                     of any remap without first making a selection. -->
                <Button x:Name="ResetAllButton"
                        Content="Reset all remaps"
                        ToolTip="Clears every per-key rebind back to factory defaults. Auto-syncs."
                        Margin="0,16,0,0"
                        Padding="14,8"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Foreground="{DynamicResource DdFg2}"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="11"
                        Cursor="Hand"
                        Click="ResetAllButton_Click"
                        AutomationProperties.Name="Reset all remaps to factory defaults"/>

                <StackPanel x:Name="EditPanel" Visibility="Collapsed">
                    <Border x:Name="CodePill"
                            Background="{DynamicResource DdSurfaceRow}"
                            BorderBrush="{DynamicResource DdBorderThin}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource DdRadiusSm}"
                            Padding="10,5"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Stretch">
                        <TextBlock x:Name="CodeText"
                                   FontFamily="{DynamicResource DdFontMono}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg2}"
                                   TextWrapping="Wrap"
                                   Text="w"/>
                    </Border>

                    <TextBlock Text="Currently bound to"
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource DdFg2}"
                               Margin="0,24,0,6"/>
                    <Border Background="{DynamicResource DdSurfaceRow}"
                            BorderBrush="{DynamicResource DdBorderThin}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource DdRadiusMd}"
                            Padding="14,12">
                        <TextBlock x:Name="CurrentBindingText"
                                   FontFamily="{DynamicResource DdFontMono}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"
                                   TextWrapping="Wrap"
                                   Text="W (default)"/>
                    </Border>

                    <Button x:Name="CaptureButton"
                            Margin="0,18,0,0"
                            Padding="14,10"
                            Background="{DynamicResource DdAccent}"
                            BorderThickness="0"
                            Foreground="{DynamicResource DdFg1}"
                            FontFamily="{DynamicResource DdFontSans}"
                            FontSize="12"
                            FontWeight="Medium"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Click="CaptureButton_Click"
                            AutomationProperties.Name="Capture replacement key">
                        <TextBlock x:Name="CaptureButtonText" Text="Rebind…"
                                   HorizontalAlignment="Center"/>
                    </Button>

                    <TextBlock x:Name="CaptureHint"
                               Text="Press any key on your physical keyboard to bind it. Esc cancels."
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="11"
                               Foreground="{DynamicResource DdAccent}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"/>

                    <Button x:Name="RestoreButton"
                            Content="Restore default binding"
                            Margin="0,12,0,0"
                            Padding="14,8"
                            Background="Transparent"
                            BorderBrush="{DynamicResource DdBorderThin}"
                            BorderThickness="1"
                            Foreground="{DynamicResource DdFg2}"
                            FontFamily="{DynamicResource DdFontSans}"
                            FontSize="11"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Click="RestoreButton_Click"/>

                    <TextBlock Text="Auto-syncs to firmware after a short pause. Use Sync now to push immediately."
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="10"
                               Foreground="{DynamicResource DdFg3}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
