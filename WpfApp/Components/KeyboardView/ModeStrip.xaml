<UserControl x:Class="WpfApp.Components.KeyboardView.ModeStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="180">
    <StackPanel>
        <!-- Three primary mode cards: RT / RDT / LW -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Rapid Trigger -->
            <Border Grid.Column="0"
                    Background="{DynamicResource DdSurface2}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusMd}"
                    Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Rapid Trigger"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"/>
                        <TextBlock Text="Triggered once pressed, reset once released. Use shallow AP plus DS/US for FPS-style instant input."
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg3}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="RtToggle" Grid.Column="1"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  Checked="RtToggle_Changed"
                                  Unchecked="RtToggle_Changed"/>
                </Grid>
            </Border>

            <!-- Release Dual-Trigger -->
            <Border Grid.Column="2"
                    Background="{DynamicResource DdSurface2}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusMd}"
                    Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Release Dual-Trigger"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"/>
                        <TextBlock Text="Two-in-one keys — press triggers one action, release triggers another."
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg3}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="RdtToggle" Grid.Column="1"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  Checked="RdtToggle_Changed"
                                  Unchecked="RdtToggle_Changed"/>
                </Grid>
            </Border>

            <!-- Last Win -->
            <Border Grid.Column="4"
                    Background="{DynamicResource DdSurface2}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusMd}"
                    Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Last Win"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"/>
                        <TextBlock Text="When opposite keys conflict (A/D), the most recent keystroke wins."
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg3}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="LwToggle" Grid.Column="1"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  Checked="LwToggle_Changed"
                                  Unchecked="LwToggle_Changed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Secondary row: Turbo, Keystroke Tracking, Reset all keys -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Turbo Mode"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="12"
                           Foreground="{DynamicResource DdFg2}"
                           VerticalAlignment="Center"/>
                <ToggleButton x:Name="TurboToggle"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              Checked="TurboToggle_Changed"
                              Unchecked="TurboToggle_Changed"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Keystroke Tracking"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="12"
                           Foreground="{DynamicResource DdFg2}"
                           VerticalAlignment="Center"/>
                <ToggleButton x:Name="KeystrokeToggle"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              Checked="KeystrokeToggle_Changed"
                              Unchecked="KeystrokeToggle_Changed"/>
            </StackPanel>

            <Button x:Name="ResetAllButton" Grid.Column="4"
                    Content="Reset all keys"
                    Padding="14,8"
                    Background="Transparent"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    Foreground="{DynamicResource DdFg2}"
                    FontFamily="{DynamicResource DdFontSans}"
                    FontSize="11"
                    Cursor="Hand"
                    Click="ResetAllButton_Click"/>
        </Grid>
    </StackPanel>
</UserControl>
