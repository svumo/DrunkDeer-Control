<UserControl x:Class="WpfApp.Components.KeyboardView.ModeStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="180">
    <StackPanel>
        <!-- Three primary mode cards: RT / RDT / LW -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Rapid Trigger -->
            <Border Grid.Column="0"
                    Background="{DynamicResource DdSurface2}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusMd}"
                    Padding="16,14"
                    ToolTip="Global Rapid Trigger master switch. Per-key DS/US (set in the right-side drawer) only take effect when this is ON.">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Rapid Trigger"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"/>
                        <TextBlock Text="Triggered once pressed, reset once released. Use shallow AP plus DS/US for FPS-style instant input."
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg3}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="RtToggle" Grid.Column="1"
                                  Content="OFF"
                                  Style="{StaticResource DdChipToggle}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  AutomationProperties.Name="Global Rapid Trigger master switch"
                                  Checked="RtToggle_Changed"
                                  Unchecked="RtToggle_Changed"/>
                </Grid>
            </Border>

            <!-- Release Dual-Trigger -->
            <Border Grid.Column="2"
                    Background="{DynamicResource DdSurface2}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusMd}"
                    Padding="16,14"
                    ToolTip="Firmware flag: pressing a key triggers one action, releasing triggers another. Per-key pairing configured via Remap (Phase H — not yet in debug UI).">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Release Dual-Trigger"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"/>
                        <TextBlock Text="Two-in-one keys — press triggers one action, release triggers another."
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg3}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="RdtToggle" Grid.Column="1"
                                  Content="OFF"
                                  Style="{StaticResource DdChipToggle}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  AutomationProperties.Name="Release Dual-Trigger master switch"
                                  Checked="RdtToggle_Changed"
                                  Unchecked="RdtToggle_Changed"/>
                </Grid>
            </Border>

            <!-- Last Win -->
            <Border Grid.Column="4"
                    Background="{DynamicResource DdSurface2}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusMd}"
                    Padding="16,14"
                    ToolTip="Firmware flag: when opposite-direction keys (A/D, W/S) conflict, the most recent keystroke wins. Applies to whichever pairs are configured.">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Last Win"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"/>
                        <TextBlock Text="When opposite keys conflict (A/D), the most recent keystroke wins."
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg3}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="LwToggle" Grid.Column="1"
                                  Content="OFF"
                                  Style="{StaticResource DdChipToggle}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  AutomationProperties.Name="Last Win master switch — most recent keystroke wins on opposite-direction keys"
                                  Checked="LwToggle_Changed"
                                  Unchecked="LwToggle_Changed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Secondary row: Turbo, Keystroke Tracking, Reset all keys -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ToggleButton x:Name="TurboToggle" Grid.Column="0"
                          Content="Turbo Mode"
                          Style="{StaticResource DdChipToggle}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Turbo Mode — reduce input latency, disables Keystroke Tracking and lighting effects"
                          ToolTip="Significantly reduces input latency. Lighting effects become static and Keystroke Tracking is forced off while Turbo is on."
                          Checked="TurboToggle_Changed"
                          Unchecked="TurboToggle_Changed"/>

            <ToggleButton x:Name="KeystrokeToggle" Grid.Column="2"
                          Content="Keystroke Tracking"
                          Style="{StaticResource DdChipToggle}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Keystroke Tracking — visualise key presses, mutually exclusive with Turbo Mode"
                          ToolTip="Tracks every keystroke for visualization. Multiple simultaneous keystrokes are tracked at once. Mutually exclusive with Turbo Mode."
                          Checked="KeystrokeToggle_Changed"
                          Unchecked="KeystrokeToggle_Changed"/>

            <StackPanel Grid.Column="4" Orientation="Vertical">
                <Button x:Name="ResetAllButton"
                        Content="Reset all keys"
                        ToolTip="Set every key back to Action Point 2.0 mm with no Rapid Trigger. Click Sync to Keyboard afterwards to push the reset to firmware."
                        Padding="14,8"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Foreground="{DynamicResource DdFg2}"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="11"
                        Cursor="Hand"
                        Focusable="False"
                        AutomationProperties.Name="Reset every key actuation back to 2.0 millimetres default"
                        Click="ResetAllButton_Click"/>
                <Button x:Name="ResetAllRemapsButton"
                        Content="Reset all bindings"
                        ToolTip="Clear every keymap remap — every key returns to its factory binding. Auto-syncs."
                        Margin="0,6,0,0"
                        Padding="14,8"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Foreground="{DynamicResource DdFg2}"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="11"
                        Cursor="Hand"
                        Focusable="False"
                        AutomationProperties.Name="Reset every remapped key back to its factory binding"
                        Click="ResetAllRemapsButton_Click"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
