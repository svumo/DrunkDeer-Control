<UserControl x:Class="WpfApp.Components.KeyboardView.ActuationDrawer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="360" d:DesignHeight="520"
             Width="360">
    <Border Background="{DynamicResource DdSurface2}"
            BorderBrush="{DynamicResource DdBorderThin}"
            BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,28">
                <!-- Eyebrow -->
                <TextBlock Text="SET ACTION POINT"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource DdFg3}"
                           Margin="0,0,0,6"/>

                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DdFg1}"
                           Text="Key · W"/>

                <!-- Empty state — shown when nothing is selected -->
                <TextBlock x:Name="EmptyHint"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="12"
                           Foreground="{DynamicResource DdFg3}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Text="Click a key on the canvas to edit its actuation point and Rapid Trigger settings. Click empty space or press Esc to clear."
                           Visibility="Collapsed"/>

                <!-- Edit panel — wraps all editable controls. Hidden when no
                     key is selected so stale values can't mislead the user. -->
                <StackPanel x:Name="EditPanel">

                <!-- Code pill — doubles as the rebind entry point. Click
                     to enter key-capture mode; the next key pressed becomes
                     the new binding. The Restore (×) button to the right
                     only appears when the slot has a non-default remap. -->
                <Border x:Name="CodePill"
                        Background="{DynamicResource DdSurfaceRow}"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource DdRadiusSm}"
                        Padding="10,5"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        Cursor="Hand"
                        ToolTip="Click to remap. Press any key (or Esc to cancel)."
                        MouseLeftButtonUp="CodePill_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CodeText"
                                   FontFamily="{DynamicResource DdFontMono}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DdFg2}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="w"/>
                        <Button x:Name="RestoreButton" Grid.Column="1"
                                Content="×"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource DdFg3}"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="4,0"
                                MinWidth="22"
                                Cursor="Hand"
                                Focusable="False"
                                ToolTip="Restore default key (remove remap)"
                                Click="RestoreButton_Click"
                                Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="RemapHint"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="10"
                           Foreground="{DynamicResource DdFg3}"
                           Margin="2,4,0,0"
                           Text="Click the chip to remap this key."/>

                <!-- AP slider section -->
                <Grid Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Actuation Point"
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource DdFg2}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ApValue" Grid.Column="1"
                               FontFamily="{DynamicResource DdFontMono}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DdFg1}"
                               Text="2.0 mm"/>
                </Grid>
                <Slider x:Name="ApSlider"
                        Margin="0,8,0,0"
                        Minimum="0.2" Maximum="2.0"
                        SmallChange="0.05" LargeChange="0.25"
                        TickFrequency="0.1"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="False"
                        AutomationProperties.Name="Actuation point in millimetres"
                        ValueChanged="ApSlider_ValueChanged"/>
                <!-- Numbered tick labels — proportional columns over the slider's
                     0.2-2.0 mm range (web-driver-verified cap on A75 Pro 0x0017,
                     see tools/captures/0x17/ap-slider-range.log). Column widths
                     reflect the tick positions within the 1.8 mm span:
                       0.2→0.5 mm = 16.67% (partial edge region)
                       0.5→1.0 mm = 27.78%
                       1.0→1.5 mm = 27.78%
                       1.5→2.0 mm = 27.78%  (sums to 100%)
                     Each label is HorizontalAlignment="Center" and
                     Grid.ColumnSpan="2" so its midpoint lands on the shared
                     column boundary — i.e. directly under the corresponding
                     tick. -->
                <Grid Margin="10,2,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="16.67*"/>  <!-- 0.2 → 0.5 mm -->
                        <ColumnDefinition Width="27.78*"/>  <!-- 0.5 → 1.0 mm -->
                        <ColumnDefinition Width="27.78*"/>  <!-- 1.0 → 1.5 mm -->
                        <ColumnDefinition Width="27.78*"/>  <!-- 1.5 → 2.0 mm -->
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="0.5"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                               Foreground="{DynamicResource DdFg3}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Text="1.0"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                               Foreground="{DynamicResource DdFg3}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Grid.ColumnSpan="2" Text="1.5"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                               Foreground="{DynamicResource DdFg3}"
                               HorizontalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="0.2 mm · shallow"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="10"
                               Foreground="{DynamicResource DdFg3}"/>
                    <TextBlock Grid.Column="1" Text="deep · 2.0 mm (default)"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="10"
                               Foreground="{DynamicResource DdFg3}"
                               TextAlignment="Right"/>
                </Grid>

                <!-- Noise-floor warning. Hall-effect switches have an analog
                     rest-position drift of roughly 0.1-0.3 mm; setting AP
                     below that threshold causes phantom triggers and key
                     "spam" without anyone touching the key. The official
                     DrunkDeer Antler driver has the same hardware ceiling,
                     so the warning is firmware-level, not a host bug. -->
                <Border x:Name="ApNoiseFloorWarning"
                        Visibility="Collapsed"
                        Background="{DynamicResource DdWarnSoft}"
                        BorderBrush="{DynamicResource DdWarn}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource DdRadiusSm}"
                        Padding="10,6"
                        Margin="0,10,0,0">
                    <TextBlock FontFamily="{DynamicResource DdFontSans}"
                               FontSize="10"
                               Foreground="{DynamicResource DdFg1}"
                               TextWrapping="Wrap"
                               Text="⚠ Below the sensor noise floor — keys may spam-trigger without being touched. Hall-effect switches have ~0.1-0.3 mm of rest drift; 0.4 mm is a practical minimum. Reproduces in the official DrunkDeer driver too."/>
                </Border>

                <!-- Heat-scale legend. Mirrors KeyCap.UpdateVisuals():
                     AP <= 1.0 mm → DdActuationLow (indigo)
                     1.0 < AP < 2.8 → neutral (default key border)
                     AP >= 2.8 mm → DdActuationHigh (purple)
                     Gradient stops are placed at the matching positions in
                     the 0.2-3.8 range so the legend lines up with the slider.
                     (1.0 - 0.2)/3.6 = 22 %, (2.8 - 0.2)/3.6 = 72 %. -->
                <Border Margin="0,12,0,0"
                        CornerRadius="{DynamicResource DdRadiusSm}"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Height="8"
                        ToolTip="How keys are tinted on the canvas based on their actuation point.">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#FF7986CB" Offset="0.0"/>
                            <GradientStop Color="#FF7986CB" Offset="0.22"/>
                            <GradientStop Color="#1AFFFFFF" Offset="0.50"/>
                            <GradientStop Color="#FF9575CD" Offset="0.78"/>
                            <GradientStop Color="#FF9575CD" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Shallow tint"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                               Foreground="{DynamicResource DdFg3}"
                               HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Text="Default"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                               Foreground="{DynamicResource DdFg3}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Deep tint"
                               FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                               Foreground="{DynamicResource DdFg3}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- RT toggle row -->
                <Border Background="{DynamicResource DdSurfaceRow}"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource DdRadiusMd}"
                        Padding="14,12"
                        Margin="0,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rapid Trigger (this key)"
                                       FontFamily="{DynamicResource DdFontSans}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource DdFg1}"/>
                            <TextBlock Text="Re-actuates on tiny direction changes — for FPS-style instant input."
                                       FontFamily="{DynamicResource DdFontSans}"
                                       FontSize="10"
                                       Foreground="{DynamicResource DdFg3}"
                                       Margin="0,3,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton x:Name="RtToggle" Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"
                                      Margin="12,0,0,0"
                                      AutomationProperties.Name="Rapid Trigger for this key"
                                      Checked="RtToggle_Changed"
                                      Unchecked="RtToggle_Changed"/>
                    </Grid>
                </Border>

                <!-- DS slider — visible when RT on -->
                <StackPanel x:Name="DsPanel" Visibility="Collapsed" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Down sensitivity"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource DdFg2}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="DsValue" Grid.Column="1"
                                   FontFamily="{DynamicResource DdFontMono}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"
                                   Text="0.5 mm"/>
                    </Grid>
                    <Slider x:Name="DsSlider" Margin="0,8,0,0"
                            Minimum="0.1" Maximum="2.0"
                            SmallChange="0.1" LargeChange="0.5"
                            TickFrequency="0.1"
                            TickPlacement="BottomRight"
                            AutomationProperties.Name="Rapid Trigger down sensitivity in millimetres"
                            ValueChanged="DsSlider_ValueChanged"/>
                    <!-- Tick labels: 0.5, 1.0, 1.5 over the 0.1-2.0 mm range.
                         Span = 1.9 mm. 0.5 → (0.5-0.1)/1.9 = 21.05 %,
                         1.0 → 47.37 %, 1.5 → 73.68 %. Padding columns absorb
                         the leading 0.1-0.5 and trailing 1.5-2.0 segments. -->
                    <Grid Margin="10,2,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="21.05*"/>  <!-- 0.1 → 0.5 -->
                            <ColumnDefinition Width="26.32*"/>  <!-- 0.5 → 1.0 -->
                            <ColumnDefinition Width="26.32*"/>  <!-- 1.0 → 1.5 -->
                            <ColumnDefinition Width="26.32*"/>  <!-- 1.5 → 2.0 -->
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="0.5"
                                   FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                                   Foreground="{DynamicResource DdFg3}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Text="1.0"
                                   FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                                   Foreground="{DynamicResource DdFg3}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Grid.ColumnSpan="2" Text="1.5"
                                   FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                                   Foreground="{DynamicResource DdFg3}"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- US slider — visible when RT on -->
                <StackPanel x:Name="UsPanel" Visibility="Collapsed" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Up sensitivity"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource DdFg2}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="UsValue" Grid.Column="1"
                                   FontFamily="{DynamicResource DdFontMono}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DdFg1}"
                                   Text="0.5 mm"/>
                    </Grid>
                    <Slider x:Name="UsSlider" Margin="0,8,0,0"
                            Minimum="0.1" Maximum="2.0"
                            SmallChange="0.1" LargeChange="0.5"
                            TickFrequency="0.1"
                            TickPlacement="BottomRight"
                            AutomationProperties.Name="Rapid Trigger up sensitivity in millimetres"
                            ValueChanged="UsSlider_ValueChanged"/>
                    <!-- Tick labels: 0.5, 1.0, 1.5 — same layout as DS. -->
                    <Grid Margin="10,2,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="21.05*"/>
                            <ColumnDefinition Width="26.32*"/>
                            <ColumnDefinition Width="26.32*"/>
                            <ColumnDefinition Width="26.32*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="0.5"
                                   FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                                   Foreground="{DynamicResource DdFg3}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Text="1.0"
                                   FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                                   Foreground="{DynamicResource DdFg3}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Grid.ColumnSpan="2" Text="1.5"
                                   FontFamily="{DynamicResource DdFontSans}" FontSize="9"
                                   Foreground="{DynamicResource DdFg3}"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Reset to default button -->
                <Button x:Name="ResetButton"
                        Content="Reset to default (2.0 mm)"
                        Margin="0,32,0,0"
                        Padding="14,8"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Foreground="{DynamicResource DdFg2}"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="11"
                        Cursor="Hand"
                        AutomationProperties.Name="Reset selected key actuation point to 2.0 millimetres default"
                        Click="ResetButton_Click"/>

                <TextBlock Text="Changes apply live. Use Sync to Keyboard on the canvas to push to firmware."
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="10"
                           Foreground="{DynamicResource DdFg3}"
                           TextWrapping="Wrap"
                           Margin="0,16,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
