<Window x:Class="WpfApp.Components.KeyboardView.KeyboardDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:kbview="clr-namespace:WpfApp.Components.KeyboardView"
        mc:Ignorable="d"
        Title="Keyboard Debug — A75 Pro"
        Height="900" Width="1320"
        MinHeight="820" MinWidth="1080"
        Background="{DynamicResource DdBgBase}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Canvas column -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PER-KEY ACTUATION — DEBUG"
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="{DynamicResource DdFg3}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="HeaderTitle"
                               Text="DrunkDeer A75 Pro · click any key to edit"
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DdFg1}"/>
                </StackPanel>
                <Button x:Name="SyncButton" Grid.Column="1"
                        Content="Sync to Keyboard"
                        Padding="16,8"
                        VerticalAlignment="Center"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="12"
                        FontWeight="Medium"
                        Background="{DynamicResource DdAccent}"
                        Foreground="{DynamicResource DdFg1}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SyncButton_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,20">
                <TextBlock x:Name="StatusText"
                           Text="Demo values seeded — WASD/E/F preconfigured. Click a key to change."
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="11"
                           Foreground="{DynamicResource DdFg2}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Phase G: global mode toggles. Wired in code-behind to a
                 ProfileSettings instance; values flow into the common-switch
                 packet on Sync. -->
            <kbview:ModeStrip x:Name="ModeStrip" Grid.Row="2" Margin="0,0,0,16"/>

            <!-- Phase F: quick-select pills above the canvas. -->
            <kbview:QuickSelectBar x:Name="QuickSelectBar" Grid.Row="3" Margin="0,0,0,12"/>

            <Border Grid.Row="4"
                    x:Name="CanvasBorder"
                    Background="{DynamicResource DdSurface1}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusLg}"
                    Padding="24,28"
                    ClipToBounds="True"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    LostMouseCapture="Canvas_LostMouseCapture">
                <Grid>
                    <StackPanel x:Name="RowsHost" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <!-- Marquee overlay. IsHitTestVisible=False so mouse events
                         pass straight through to the Border, but Z-orders above
                         the caps so the rectangle is drawn on top. -->
                    <Canvas x:Name="MarqueeLayer" IsHitTestVisible="False">
                        <Rectangle x:Name="MarqueeRect"
                                   Width="0" Height="0"
                                   Visibility="Collapsed"
                                   Fill="#26 9575CD"
                                   Stroke="#80 9575CD"
                                   StrokeThickness="1"
                                   StrokeDashArray="3,2"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Phase F: bottom preset bar (FPS / Typing / Reset). -->
            <kbview:PresetBar x:Name="PresetBar" Grid.Row="5" Margin="0,16,0,0"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                <Rectangle Width="9" Height="9" RadiusX="2" RadiusY="2" Fill="#FFFFAB40" VerticalAlignment="Center"/>
                <TextBlock Text="uncertain slot mapping — confirm on hardware"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="11"
                           Foreground="{DynamicResource DdFg3}"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Drawer column -->
        <kbview:ActuationDrawer x:Name="Drawer" Grid.Column="1"/>
    </Grid>
</Window>
