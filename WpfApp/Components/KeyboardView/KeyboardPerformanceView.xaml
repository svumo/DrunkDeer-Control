<UserControl x:Class="WpfApp.Components.KeyboardView.KeyboardPerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:kbview="clr-namespace:WpfApp.Components.KeyboardView"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1320"
             Background="{DynamicResource DdBgBase}"
             Focusable="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Canvas column -->
        <Grid Grid.Column="0" Margin="16,16,12,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SegmentedTabStyle hoisted to Themes/CustomStyles.xaml (shared
                 with the top-level Keyboard / Lighting nav strip). -->

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="PER-KEY ACTUATION — DEBUG"
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="{DynamicResource DdFg3}"
                               Margin="0,0,0,4"
                               TextTrimming="CharacterEllipsis"/>
                    <!-- TextTrimming + ToolTip so the title ellipsizes
                         instead of clipping behind the action buttons
                         when the window is narrow; hover reveals the
                         full text. ToolTip binds to .Text so it always
                         matches whatever RefreshHeaderAndBanner set. -->
                    <TextBlock x:Name="HeaderTitle"
                               Text="DrunkDeer A75 Pro · click any key to edit"
                               FontFamily="{DynamicResource DdFontSans}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DdFg1}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                </StackPanel>
                <Button x:Name="DownloadsButton" Grid.Column="1"
                        Content="Manual &amp; firmware"
                        ToolTip="Opens drunkdeer.com/pages/downloads — official manuals and firmware updates for all DrunkDeer keyboards."
                        Padding="12,8"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="11"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Foreground="{DynamicResource DdFg2}"
                        Cursor="Hand"
                        Click="DownloadsButton_Click"/>
                <Button x:Name="OpenLogButton" Grid.Column="2"
                        Content="Open log folder"
                        ToolTip="Opens File Explorer with debug.log selected — drag it anywhere to share."
                        Padding="12,8"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="11"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DdBorderThin}"
                        BorderThickness="1"
                        Foreground="{DynamicResource DdFg2}"
                        Cursor="Hand"
                        Click="OpenLogButton_Click"/>
                <Button x:Name="SyncButton" Grid.Column="3"
                        Content="Sync now"
                        ToolTip="Changes sync automatically after a short pause. Use this to push immediately without waiting."
                        Padding="16,8"
                        VerticalAlignment="Center"
                        FontFamily="{DynamicResource DdFontSans}"
                        FontSize="12"
                        FontWeight="Medium"
                        Background="{DynamicResource DdAccent}"
                        Foreground="{DynamicResource DdFg1}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SyncButton_Click"/>
            </Grid>

            <!-- Phase H tab toggle was removed: remapping now happens
                 directly from the right-side drawer (click the code pill,
                 press a key). The Performance/Remap split was confusing
                 and the canvas re-flow was disorienting. -->
            <StackPanel Grid.Row="1" Margin="0,0,0,0"/>

            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,16">
                <!-- Firmware-update banner. Hidden by default; shown when
                     FirmwareUpdateChecker reports the connected keyboard's
                     firmware is behind what DrunkDeer publishes. The whole
                     border is a clickable hyperlink opening the downloads
                     page. Dismiss (×) hides for this session only — the
                     24h cache in Settings governs how often we re-check. -->
                <Border x:Name="FirmwareBanner"
                        Visibility="Collapsed"
                        Background="{DynamicResource DdAccentSoft}"
                        BorderBrush="{DynamicResource DdAccent}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource DdRadiusMd}"
                        Padding="12,8"
                        Margin="0,0,0,10"
                        Cursor="Hand"
                        MouseLeftButtonUp="FirmwareBanner_MouseLeftButtonUp">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FirmwareBannerText"
                                   Grid.Column="0"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="12"
                                   Foreground="{DynamicResource DdFg1}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Text="Firmware update available — click to open downloads page."/>
                        <Button x:Name="FirmwareBannerDismiss"
                                Grid.Column="1"
                                Content="×"
                                Width="22" Height="22"
                                Margin="8,0,0,0"
                                Padding="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource DdFg2}"
                                Cursor="Hand"
                                ToolTip="Dismiss for this session"
                                Click="FirmwareBannerDismiss_Click"/>
                    </Grid>
                </Border>
                <!-- Model-identification banner. Two states (controlled in
                     code-behind by ShowModelBanner):
                       - Unrecognized: keyboard connected but resolver couldn't
                         match TypeCode or PID. Warning tone, A75 Pro layout
                         used as best-effort fallback.
                       - Beta: model resolved but hardware behavior not yet
                         verified on this side (anything outside A75 Pro /
                         A75 Ultra / G65). Softer info tone.
                     Click opens a pre-filled GitHub issue; × dismisses for
                     this session. -->
                <!-- Firmware-changed banner. Shows once per (PID, firmware)
                     transition: when the connected keyboard's firmware
                     differs from the last-seen value stored in settings,
                     warn the user that RDT/LW pair tables may need
                     recreating (the firmware doesn't always migrate them
                     cleanly across versions — see Known Issues #5). The
                     dismiss × stamps the current firmware as the new
                     last-known so it doesn't fire again until the NEXT
                     version change. -->
                <Border x:Name="FirmwareChangedBanner"
                        Visibility="Collapsed"
                        Background="{DynamicResource DdWarnSoft}"
                        BorderBrush="{DynamicResource DdWarn}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource DdRadiusMd}"
                        Padding="12,8"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FirmwareChangedBannerText"
                                   Grid.Column="0"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="12"
                                   Foreground="{DynamicResource DdFg1}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="FirmwareChangedBannerDismiss"
                                Grid.Column="1"
                                Content="×"
                                Width="22" Height="22"
                                Margin="8,0,0,0"
                                Padding="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource DdFg2}"
                                Cursor="Hand"
                                ToolTip="Got it — don't show again until next firmware change"
                                Click="FirmwareChangedBannerDismiss_Click"/>
                    </Grid>
                </Border>
                <Border x:Name="ModelStatusBanner"
                        Visibility="Collapsed"
                        Background="{DynamicResource DdWarnSoft}"
                        BorderBrush="{DynamicResource DdWarn}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource DdRadiusMd}"
                        Padding="12,8"
                        Margin="0,0,0,10"
                        Cursor="Hand"
                        MouseLeftButtonUp="ModelStatusBanner_MouseLeftButtonUp">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ModelStatusBannerText"
                                   Grid.Column="0"
                                   FontFamily="{DynamicResource DdFontSans}"
                                   FontSize="12"
                                   Foreground="{DynamicResource DdFg1}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="ModelStatusBannerDismiss"
                                Grid.Column="1"
                                Content="×"
                                Width="22" Height="22"
                                Margin="8,0,0,0"
                                Padding="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource DdFg2}"
                                Cursor="Hand"
                                ToolTip="Dismiss for this session"
                                Click="ModelStatusBannerDismiss_Click"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="StatusText"
                           Text="Demo values seeded — WASD/E/F preconfigured. Click a key to change."
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="11"
                           Foreground="{DynamicResource DdFg2}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Phase G: global mode toggles. Wired in code-behind to a
                 ProfileSettings instance; values flow into the common-switch
                 packet on Sync. Hidden in Remap mode. -->
            <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,16">
                <kbview:ModeStrip x:Name="ModeStrip" Margin="0,0,0,8"/>
                <!-- LW pair editor — visible only when Last Win is on AND
                     we're in Performance (not Remap) mode. Pairs persist
                     in Settings.LastWinPairsJson. -->
                <kbview:LastWinPairsBar x:Name="LwPairsBar" Visibility="Collapsed"/>
                <!-- RDT pair editor — visible only when Release Dual-Trigger
                     is on. Pairs persist in Settings.ReleaseDualTriggerPairsJson.
                     LW + RDT are mutually exclusive at the toggle level so only
                     one of these bars is ever visible at a time. -->
                <kbview:ReleaseDualTriggerPairsBar x:Name="RdtPairsBar" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Phase F: quick-select pills above the canvas. -->
            <kbview:QuickSelectBar x:Name="QuickSelectBar" Grid.Row="4" Margin="0,0,0,12"/>

            <Border Grid.Row="5"
                    x:Name="CanvasBorder"
                    Background="{DynamicResource DdSurface1}"
                    BorderBrush="{DynamicResource DdBorderThin}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource DdRadiusLg}"
                    Padding="16,22"
                    ClipToBounds="True"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    LostMouseCapture="Canvas_LostMouseCapture">
                <Grid>
                    <StackPanel x:Name="RowsHost" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <!-- Marquee overlay. IsHitTestVisible=False so mouse events
                         pass straight through to the Border, but Z-orders above
                         the caps so the rectangle is drawn on top. -->
                    <Canvas x:Name="MarqueeLayer" IsHitTestVisible="False">
                        <Rectangle x:Name="MarqueeRect"
                                   Width="0" Height="0"
                                   Visibility="Collapsed"
                                   Fill="#269575CD"
                                   Stroke="#809575CD"
                                   StrokeThickness="1"
                                   StrokeDashArray="3,2"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Phase F: bottom preset bar (FPS / Typing / Reset). Hidden in Remap mode. -->
            <kbview:PresetBar x:Name="PresetBar" Grid.Row="6" Margin="0,16,0,0"/>

            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                <Rectangle Width="9" Height="9" RadiusX="2" RadiusY="2" Fill="#FFFFAB40" VerticalAlignment="Center"/>
                <TextBlock Text="uncertain slot mapping — confirm on hardware"
                           FontFamily="{DynamicResource DdFontSans}"
                           FontSize="11"
                           Foreground="{DynamicResource DdFg3}"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Drawer column — the single right-side drawer now handles both
             actuation tuning and remapping (click the code pill to rebind).
             The separate RemapDrawer is gone. The RdtPairDrawer occupies
             the same slot and is shown mutually-exclusively when the user
             is editing an RDT pair. -->
        <Grid Grid.Column="1">
            <kbview:ActuationDrawer x:Name="Drawer"/>
            <kbview:RdtPairDrawer x:Name="RdtDrawer" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
