<Window x:Class="WpfApp.Components.ProcessSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp.Components"
        mc:Ignorable="d"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Title="Process Triggers" Height="460" Width="600"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <local:ProcessToImageConverter x:Key="ProcessToImageConverter" />
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
            Background="{StaticResource GlassBg}" Name="DialogBorder" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_Drag" Padding="16,0">
                <Grid>
                    <TextBlock Name="DialogTitle" Text="Process Triggers" FontSize="12"
                               FontWeight="SemiBold" Foreground="{StaticResource TextW2}"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="26" Height="26" Padding="0" Foreground="{StaticResource TextW3}">
                        <materialDesign:PackIcon Kind="WindowClose" Width="13" Height="13"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Two panels -->
            <Grid Grid.Row="1" Margin="16,14,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Assigned -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Padding="12,8" CornerRadius="10,10,0,0"
                                Background="{StaticResource RowBg}">
                            <TextBlock Text="Assigned" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextW3}"/>
                        </Border>
                        <ListBox Grid.Row="1" Name="storedProcesses"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,4">
                                        <Image Source="{Binding ProcessPath, Converter={StaticResource ProcessToImageConverter}}"
                                               Height="16" Width="16" Margin="0,0,8,0"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding ProcessName}" FontSize="12"
                                                   Foreground="{StaticResource TextW}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Arrows -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                    <Button Click="ActiveToStoredClick" ToolTip="Assign"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="28" Height="28" Padding="0" Margin="0,3"
                            Foreground="{StaticResource TextW3}">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <Button Click="RemoveStoredClick" ToolTip="Remove"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="28" Height="28" Padding="0" Margin="0,3"
                            Foreground="{StaticResource TextW3}">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                    <Button Click="RefreshActiveProcesses_Click" ToolTip="Refresh"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="28" Height="28" Padding="0" Margin="0,10,0,3"
                            Foreground="{StaticResource TextW3}" Opacity="0.7">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </StackPanel>

                <!-- Running -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}" Margin="0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Padding="12,8" CornerRadius="10,10,0,0"
                                Background="{StaticResource RowBg}">
                            <TextBlock Text="Running" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextW3}"/>
                        </Border>
                        <ListBox Grid.Row="1" Name="activeProcesses"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,4">
                                        <Image Source="{Binding ProcessPath, Converter={StaticResource ProcessToImageConverter}}"
                                               Height="16" Width="16" Margin="0,0,8,0"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding ProcessName}" FontSize="12"
                                                   Foreground="{StaticResource TextW}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom -->
            <Border Grid.Row="2" Padding="16,10" Background="{StaticResource HeaderBg}"
                    CornerRadius="0,0,12,12">
                <Button Click="AddProcessManually_Click"
                        Style="{StaticResource GlassSubtleBtn}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Browse..." FontSize="11.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
