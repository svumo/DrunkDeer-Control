<Window x:Class="WpfApp.Components.ProcessSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp.Components"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{StaticResource SurfaceBrush}"
        Title="Process Triggers" Height="480" Width="620"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <local:ProcessToImageConverter x:Key="ProcessToImageConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Name="DialogTitle" Text="Process Triggers"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- Two panels -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Assigned -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceContainerBrush}"
                    CornerRadius="10" BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="14,10" CornerRadius="10,10,0,0"
                            Background="{StaticResource SurfaceElevatedBrush}">
                        <TextBlock Text="ASSIGNED" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   />
                    </Border>

                    <ListBox Grid.Row="1" Name="storedProcesses"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="6,5">
                                    <Image Source="{Binding ProcessPath, Converter={StaticResource ProcessToImageConverter}}"
                                           Height="18" Width="18" Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding ProcessName}" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                <Button Click="ActiveToStoredClick" ToolTip="Assign trigger"
                        Style="{StaticResource MaterialDesignIconForegroundButton}" Margin="0,3"
                        Foreground="{StaticResource TextSecondaryBrush}">
                    <materialDesign:PackIcon Kind="ChevronLeft" Width="22" Height="22"/>
                </Button>
                <Button Click="RemoveStoredClick" ToolTip="Remove trigger"
                        Style="{StaticResource MaterialDesignIconForegroundButton}" Margin="0,3"
                        Foreground="{StaticResource TextSecondaryBrush}">
                    <materialDesign:PackIcon Kind="ChevronRight" Width="22" Height="22"/>
                </Button>
                <Button Click="RefreshActiveProcesses_Click" ToolTip="Refresh"
                        Style="{StaticResource MaterialDesignIconForegroundButton}" Margin="0,10,0,3"
                        Foreground="{StaticResource TextTertiaryBrush}">
                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
            </StackPanel>

            <!-- Running -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceContainerBrush}"
                    CornerRadius="10" BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="14,10" CornerRadius="10,10,0,0"
                            Background="{StaticResource SurfaceElevatedBrush}">
                        <TextBlock Text="RUNNING" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   />
                    </Border>

                    <ListBox Grid.Row="1" Name="activeProcesses"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="6,5">
                                    <Image Source="{Binding ProcessPath, Converter={StaticResource ProcessToImageConverter}}"
                                           Height="18" Width="18" Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding ProcessName}" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Add manually -->
        <Button Grid.Row="2" Click="AddProcessManually_Click"
                Style="{StaticResource SubtleButton}"
                HorizontalAlignment="Left" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Browse..." VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
