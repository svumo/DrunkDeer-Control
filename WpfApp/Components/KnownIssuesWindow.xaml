<Window x:Class="WpfApp.Components.KnownIssuesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Title="Known issues" Height="560" Width="560"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Minimal themed scrollbar: 6px-wide rounded thumb, no buttons, no
             track chrome. Matches the surface palette used by the rest of the
             window so the scroller reads as part of the panel, not a Win32
             control bolted on. -->
        <Style x:Key="DdScrollThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{StaticResource DdBorderMed}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Margin="2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DdFg3}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DdScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DdScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollViewer}" x:Key="DdScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"/>
                            <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                       Style="{StaticResource DdScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Margin="0,8,4,8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="{StaticResource DdRadiusXl}" BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
            Background="{StaticResource DdBgGlass}" ClipToBounds="True"
            Effect="{StaticResource DdShadow3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource DdBgHeader}" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_Drag" Padding="16,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Foreground="{StaticResource DdFg2}"/>
                        <TextBlock Text="Known issues" FontSize="{StaticResource DdFsBase}"
                                   FontWeight="SemiBold" Foreground="{StaticResource DdFg2}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="26" Height="26" Padding="0" Foreground="{StaticResource DdFg3}"
                            AutomationProperties.Name="Close">
                        <materialDesign:PackIcon Kind="WindowClose" Width="13" Height="13"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource DdScrollViewer}"
                          Padding="22,18,22,22">
                <StackPanel>

                    <TextBlock Text="These are quirks we've documented but can't fix from the app — usually because the behavior lives in the keyboard's firmware, or because Windows reserves a key when it's bound as a hotkey. Here so you know what's expected vs. broken."
                               FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg3}"
                               TextWrapping="Wrap" Margin="0,0,0,18" LineHeight="20"/>

                    <!-- Issue 1: Q/Z LED on Last Win -->
                    <Border Background="{StaticResource DdSurfaceRow}"
                            BorderBrush="{StaticResource DdBorderThin}" BorderThickness="1"
                            CornerRadius="{StaticResource DdRadiusMd}" Padding="16,14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="LedOn" Width="22" Height="22"
                                                     VerticalAlignment="Top" Margin="0,2,14,0"
                                                     Foreground="{StaticResource DdAccent}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Q and Z light up when Last Win is enabled"
                                           FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                           Foreground="{StaticResource DdFg1}"/>
                                <TextBlock FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg2}"
                                           Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="19"
                                           Text="As soon as Last Win is on, the firmware lights the Q and Z keys white — even if you haven't paired them. This is a firmware-side indicator, not a key being paired or remapped. The behavior is identical in the official Antler web driver."/>
                                <TextBlock FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                           Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Status: not fixable from this app. Would need a keyboard firmware update from DrunkDeer."/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Issue 2: web driver overrides until sync -->
                    <Border Background="{StaticResource DdSurfaceRow}"
                            BorderBrush="{StaticResource DdBorderThin}" BorderThickness="1"
                            CornerRadius="{StaticResource DdRadiusMd}" Padding="16,14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="WebSync" Width="22" Height="22"
                                                     VerticalAlignment="Top" Margin="0,2,14,0"
                                                     Foreground="{StaticResource DdAccent}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Antler web driver overrides this app until you re-sync"
                                           FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                           Foreground="{StaticResource DdFg1}"/>
                                <TextBlock FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg2}"
                                           Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="19"
                                           Text="If you open drunkdeer-antler.com while this app is running and click Save, the keyboard takes the web driver's settings. The profile here still shows as active in the sidebar — but the actual keyboard state is whatever the web driver pushed last."/>
                                <TextBlock FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                           Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Fix: hit Sync to Keyboard, or re-press your profile hotkey, to push this app's profile back onto the keyboard."/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Issue 3: single-key profile hotkeys -->
                    <Border Background="{StaticResource DdSurfaceRow}"
                            BorderBrush="{StaticResource DdBorderThin}" BorderThickness="1"
                            CornerRadius="{StaticResource DdRadiusMd}" Padding="16,14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="KeyboardOutline" Width="22" Height="22"
                                                     VerticalAlignment="Top" Margin="0,2,14,0"
                                                     Foreground="{StaticResource DdAccent}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Single-key profile hotkeys swallow that key"
                                           FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                           Foreground="{StaticResource DdFg1}"/>
                                <TextBlock FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg2}"
                                           Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="19"
                                           Text="If you bind a profile to a single key like [, that key will switch profiles and won't type [ anymore. Windows hands the keystroke to whichever app registered the hotkey first, and we register it globally so it works no matter what's focused."/>
                                <TextBlock FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                           Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Fix: bind to a modifier combo (e.g. Alt+[, Ctrl+Shift+P). The modifier guarantees normal typing of the key still works."/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Issue 4: actuation-point noise floor at 0.2 mm -->
                    <Border Background="{StaticResource DdSurfaceRow}"
                            BorderBrush="{StaticResource DdBorderThin}" BorderThickness="1"
                            CornerRadius="{StaticResource DdRadiusMd}" Padding="16,14"
                            Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="WaveformLine" Width="22" Height="22"
                                                     VerticalAlignment="Top" Margin="0,2,14,0"
                                                     Foreground="{StaticResource DdAccent}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Keys spam-trigger at very low actuation points (~0.2 mm)"
                                           FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                           Foreground="{StaticResource DdFg1}"/>
                                <TextBlock FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg2}"
                                           Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="19"
                                           Text="Setting a key's actuation point below about 0.4 mm causes phantom presses — the key fires repeatedly even when nothing is touching it. This is a property of the Hall-effect (magnetic) switches: every sensor has a tiny rest-position drift of roughly 0.1-0.3 mm, and the firmware treats any value above the threshold as 'pressed'. Below the drift floor, the sensor's natural noise crosses the threshold on its own. The official DrunkDeer Antler driver reproduces the same behavior at the same range."/>
                                <TextBlock FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                           Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Fix: keep actuation at 0.4 mm or higher. The drawer flags values below 0.4 mm with an inline warning."/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
