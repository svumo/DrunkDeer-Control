<Window x:Class="WpfApp.Components.ErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="DrunkDeer Control — Error"
        Icon="/Resources/drunkdeer-control-logo.ico"
        Height="500" Width="560"
        MinHeight="400" MinWidth="480"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True">

    <Border CornerRadius="{StaticResource DdRadiusXl}" BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
            Background="{StaticResource DdBgGlass}" ClipToBounds="True"
            Effect="{StaticResource DdShadow3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0" Background="{StaticResource DdBgHeader}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="AlertCircle" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{StaticResource DdDanger}"/>
                        <TextBlock Text="SOMETHING WENT WRONG" FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                   Foreground="{StaticResource DdFg2}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2" Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="28" Height="28" Padding="0" Foreground="{StaticResource DdFg3}">
                        <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== BODY ===== -->
            <Grid Grid.Row="1" Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Lead -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="The app hit an unexpected error."
                               FontSize="{StaticResource DdFsLg}" FontWeight="SemiBold"
                               Foreground="{StaticResource DdFg1}"/>
                    <TextBlock Text="It will keep running, but the action you just took may not have completed. Please report this so it can be fixed."
                               FontSize="{StaticResource DdFsBase}" Foreground="{StaticResource DdFg3}"
                               TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Discord card -->
                <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,0,0,10" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Discord" Width="22" Height="22"
                                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                                 Foreground="{StaticResource DdAccent}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Report on Discord" FontSize="{StaticResource DdFsBase}"
                                       Foreground="{StaticResource DdFg1}"/>
                            <TextBlock Text="DM @proxyful with the details below — usually fixed within a few days."
                                       FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}" Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="{StaticResource DdRadiusSm}" Background="{StaticResource DdSurfaceRow}"
                                BorderBrush="{StaticResource DdBorderThin}" BorderThickness="1"
                                Padding="10,4" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="@proxyful" FontSize="{StaticResource DdFsSm}" FontFamily="{StaticResource DdFontMono}"
                                       Foreground="{StaticResource DdFg1}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Details box -->
                <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,0,0,10" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Error details" FontSize="{StaticResource DdFsXs}" FontWeight="SemiBold"
                                   Foreground="{StaticResource DdFg3}" Margin="14,11,14,4"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto" Padding="14,0,14,11">
                            <TextBox Name="DetailsBox" IsReadOnly="True" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource DdFg2}"
                                     FontFamily="{StaticResource DdFontMono}" FontSize="{StaticResource DdFsSm}"
                                     TextWrapping="NoWrap" AcceptsReturn="True"
                                     IsReadOnlyCaretVisible="False"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="CopyDetails_Click"
                            Style="{StaticResource GlassSubtleBtn}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentCopy" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Name="CopyButtonText" Text="Copy details" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Click="Continue_Click" Content="Continue"
                            Style="{StaticResource GlassSubtleBtn}" Margin="0,0,6,0"/>
                    <Button Grid.Column="3" Click="Quit_Click" Content="Quit"
                            Style="{StaticResource GlassPillBtn}"/>
                </Grid>

                <TextBlock Grid.Row="4" FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                           Text="A copy of these details has been written to debug.log in your AppData."
                           Margin="0,10,0,0" HorizontalAlignment="Center" Opacity="0.7"/>
            </Grid>
        </Grid>
    </Border>
</Window>
