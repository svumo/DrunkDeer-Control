<Window x:Class="WpfApp.WebHid.WebHidConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="DrunkDeer Control"
        Icon="/Resources/drunkdeer-control-logo.ico"
        Height="340" Width="480"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True" Topmost="True"
        ResizeMode="NoResize"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True">

    <Border CornerRadius="{StaticResource DdRadiusXl}" BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
            Background="{StaticResource DdBgGlass}" ClipToBounds="True"
            Effect="{StaticResource DdShadow3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource DdBgHeader}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/drunkdeer-control-logo.png" Width="20" Height="20"
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="DRUNKDEER CONTROL" FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                   Foreground="{StaticResource DdFg2}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Click="CancelButton_Click"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="28" Height="28" Padding="0" Foreground="{StaticResource DdFg3}">
                        <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="24,18,24,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Lead -->
                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="One-time keyboard setup"
                               FontSize="{StaticResource DdFsXl}" FontWeight="SemiBold"
                               Foreground="{StaticResource DdFg1}"/>
                    <TextBlock Text="Your DrunkDeer A75 Pro uses a firmware variant that needs a browser-based connection to configure. This is a one-time grant — once you select your keyboard, it will reconnect automatically every time the app launches."
                               FontSize="{StaticResource DdFsBase}" Foreground="{StaticResource DdFg3}"
                               TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                </StackPanel>

                <!-- Info card -->
                <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="What happens next"
                                   FontSize="{StaticResource DdFsSm}" FontWeight="SemiBold"
                                   Foreground="{StaticResource DdFg2}" Margin="0,0,0,8"/>
                        <TextBlock FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg3}"
                                   TextWrapping="Wrap" LineHeight="18">
                            <Run Text="1. A small window opens with a"/>
                            <Run Text=" Show device picker " FontWeight="SemiBold" Foreground="{StaticResource DdFg2}"/>
                            <Run Text="button."/>
                            <LineBreak/>
                            <Run Text="2. Click it. Windows shows a list of HID devices."/>
                            <LineBreak/>
                            <Run Text="3. Select"/>
                            <Run Text=" DrunkDeer A75 Pro " FontWeight="SemiBold" Foreground="{StaticResource DdFg2}"/>
                            <Run Text="and click Connect."/>
                            <LineBreak/>
                            <Run Text="4. The window closes and your keyboard is ready."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Name="StatusText" Text=""
                               FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                               VerticalAlignment="Center" Opacity="0.7"/>
                    <Button Grid.Column="1" Name="CancelButton"
                            Click="CancelButton_Click"
                            Style="{StaticResource GlassSubtleBtn}" Margin="0,0,8,0"
                            Content="Cancel"/>
                    <Button Grid.Column="2" Name="ContinueButton"
                            Click="ContinueButton_Click"
                            Style="{StaticResource GlassPillBtn}" IsDefault="True"
                            Content="Continue"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
