<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp.Components"
        xmlns:kbview="clr-namespace:WpfApp.Components.KeyboardView"
        mc:Ignorable="d"
        Title="DrunkDeer Control"
        Icon="/Resources/drunkdeer-control-logo.ico"
        MinHeight="880" MinWidth="1280"
        Height="1000" Width="1440"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded" StateChanged="Window_StateChanged"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        AllowDrop="True" PreviewDragOver="OnWindowPreviewDragOver" Drop="OnWindowDrop"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True">

    <Window.Resources>
        <local:ProcessTriggerToNameConverter x:Key="ProcessTriggerToNameConverter"/>
        <local:ProcessToImageConverter x:Key="ProcessToImageConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
    </Window.Resources>

    <!-- Outer border = the glass pane -->
    <Border CornerRadius="{StaticResource DdRadiusXl}" BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
            Background="{StaticResource DdBgGlass}" ClipToBounds="True"
            Name="OuterBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Shared help popup (ToolTip doesn't work on AllowsTransparency windows) -->
            <Popup Name="HelpPopup" AllowsTransparency="True" PopupAnimation="Fade"
                   Placement="Bottom" StaysOpen="True" IsOpen="False"
                   HorizontalOffset="8" VerticalOffset="4">
                <Border Background="{StaticResource DdBgGlass}" BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
                        CornerRadius="{StaticResource DdRadiusSm}" Padding="10,8"
                        Effect="{StaticResource MaterialDesignShadowDepth2}"
                        MouseEnter="HelpPopup_MouseEnter" MouseLeave="HelpPopup_MouseLeave">
                    <TextBlock Name="HelpPopupText" Text="" Foreground="{StaticResource DdFg1}"
                               FontSize="{StaticResource DdFsBase}" TextWrapping="Wrap" MaxWidth="280"/>
                </Border>
            </Popup>

            <!-- ==================== TITLE BAR ==================== -->
            <Border Grid.Row="0" Background="{StaticResource DdBgHeader}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/drunkdeer-control-logo.png" Width="26" Height="26" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="DRUNKDEER CONTROL" FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                   FontFamily="{StaticResource DdFontSans}"
                                   Foreground="{StaticResource DdFg2}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Active profile pill -->
                    <Border Grid.Column="2" CornerRadius="{StaticResource DdRadiusLg}" Padding="10,4"
                            Background="{StaticResource DdSurfaceRow}" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Name="ActiveProfileDot" Margin="0,0,8,0"
                                     VerticalAlignment="Center" Fill="{StaticResource DdNeutral}"/>
                            <TextBlock Name="ActiveProfileText" Text="No profile active"
                                       FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg2}"
                                       FontFamily="{StaticResource DdFontSans}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Connection pill. Dot colour encodes the FirmwareCapabilities
                         tier of the currently-connected keyboard:
                           green  = Verified  (model + firmware tested end-to-end)
                           yellow = Beta      (model known, firmware unverified)
                           red    = Unknown   (model not recognized; Sync is disabled)
                           gray   = Disconnected
                         TierBadge text shows the tier word inline ("verified" /
                         "beta" / "unrecognized") — visible at a glance without
                         hover. ToolTip doesn't render on AllowsTransparency
                         windows so we avoid the hover-affordance entirely. -->
                    <Border Grid.Column="3" Name="ConnectionPill"
                            CornerRadius="{StaticResource DdRadiusLg}" Padding="10,4"
                            Background="{StaticResource DdSurfaceRow}" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Name="ConnectionDot" Margin="0,0,8,0"
                                     VerticalAlignment="Center" Fill="{StaticResource DdNeutral}"/>
                            <TextBlock Name="KeyboardStatusText" Text="No keyboard"
                                       FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg2}"
                                       FontFamily="{StaticResource DdFontSans}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Name="TierBadge" Visibility="Collapsed"
                                       Margin="8,0,0,0"
                                       FontSize="{StaticResource DdFsXs}"
                                       Foreground="{StaticResource DdFg3}"
                                       FontFamily="{StaticResource DdFontSans}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Options button -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">

                        <!-- Known issues entry point. Opens KnownIssuesWindow as a
                             modal listing host-side-unfixable quirks (firmware LED
                             indicator on LW, web-driver override, single-key hotkey
                             swallow). Cheaper to document inline than answer the
                             same questions in GitHub issues. -->
                        <Button Name="KnownIssuesButton" Click="KnownIssuesButton_Click"
                                Style="{StaticResource MaterialDesignToolButton}"
                                IsTabStop="False"
                                Width="28" Height="28" Padding="0" Margin="0,0,2,0"
                                Foreground="{StaticResource DdFg3}"
                                ToolTip="Known issues">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="15" Height="15"/>
                        </Button>

                        <!-- Settings entry point. When an update is available the gear
                             swaps to a bell + indigo dot, so users notice without having
                             to randomly open Settings. State driven from MainWindow.xaml.cs:
                             SetOptionsButtonNotification(visible). -->
                        <Grid Width="28" Height="28">
                            <Button Name="OptionsButton" Click="OptionsButton_Click"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    IsTabStop="False"
                                    Width="28" Height="28" Padding="0"
                                    Foreground="{StaticResource DdFg3}"
                                    ToolTip="Settings &amp; Keybinds">
                                <materialDesign:PackIcon Name="OptionsButtonIcon"
                                                         Kind="Tune" Width="15" Height="15"/>
                            </Button>
                            <!-- Notification dot — overlay positioned in the upper-right
                                 corner. Hit-test transparent so clicks still go to the button. -->
                            <Ellipse Name="OptionsNotificationDot" Visibility="Collapsed"
                                     Width="8" Height="8"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     Margin="0,4,4,0"
                                     Fill="{StaticResource DdInfo}"
                                     Stroke="{StaticResource DdBgBase}" StrokeThickness="1.5"
                                     IsHitTestVisible="False"/>
                        </Grid>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Click="MinimizeButton_Click" Style="{StaticResource MaterialDesignToolButton}"
                                IsTabStop="False"
                                Width="28" Height="28" Padding="0" Foreground="{StaticResource DdFg3}"
                                AutomationProperties.Name="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button Name="MaximizeButton" Click="MaximizeButton_Click" Style="{StaticResource MaterialDesignToolButton}"
                                IsTabStop="False"
                                Width="28" Height="28" Padding="0" Foreground="{StaticResource DdFg3}" Margin="4,0,0,0"
                                AutomationProperties.Name="Maximize">
                            <materialDesign:PackIcon Name="MaximizeIcon" Kind="WindowMaximize" Width="14" Height="14"/>
                        </Button>
                        <Button Click="CloseButton_Click" Style="{StaticResource MaterialDesignToolButton}"
                                IsTabStop="False"
                                Width="28" Height="28" Padding="0" Foreground="{StaticResource DdFg3}" Margin="4,0,0,0"
                                AutomationProperties.Name="Close">
                            <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== OPTIONS OVERLAY ==================== -->
            <!-- In-window overlay avoids WPF transparent-window Popup clipping -->
            <Grid Name="OptionsOverlay" Grid.Row="0" Grid.RowSpan="2"
                  Panel.ZIndex="200" Visibility="Collapsed">
                <!-- Transparent backdrop — click outside to dismiss -->
                <Rectangle Fill="Transparent" MouseLeftButtonDown="OptionsOverlay_Dismiss"/>
                <!-- Settings panel anchored to top-right -->
                <Border Background="{StaticResource DdBgGlass}"
                        BorderBrush="{StaticResource DdBorderMed}"
                        BorderThickness="1" CornerRadius="{StaticResource DdRadiusXl}"
                        Padding="16,16,16,24" Width="320"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,48,48,0"
                        Effect="{StaticResource DdShadow3}">
                    <StackPanel>
                        <!-- Update banner — state machine driven from MainWindow.xaml.cs.
                             Layout is text-on-top, buttons-on-bottom so the title
                             and subtitle always get full width (the overlay is only
                             320px wide, buttons + text on the same row truncated). -->
                        <Border Name="UpdateBanner" Visibility="Collapsed"
                                Background="{StaticResource DdSurfaceRow}"
                                BorderBrush="{StaticResource DdAccent}" BorderThickness="1"
                                CornerRadius="{StaticResource DdRadiusMd}" Padding="12,10" Margin="0,0,0,14">
                            <StackPanel>
                                <!-- Row 1: icon + text (full width) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Name="UpdateBannerIcon"
                                                             Kind="Download" Width="18" Height="18"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"
                                                             Foreground="{StaticResource DdAccent}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Name="UpdateBannerTitle" Text="Update available"
                                                   FontSize="{StaticResource DdFsBase}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DdFg1}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Name="UpdateBannerSubtitle" Text=""
                                                   FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                                   Margin="0,1,0,0" FontFamily="{StaticResource DdFontMono}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Row 2: thin progress bar (visible only during download) -->
                                <ProgressBar Name="UpdateProgressBar" Visibility="Collapsed"
                                             Height="4" Margin="0,8,0,0"
                                             Background="{StaticResource DdSurface1}"
                                             Foreground="{StaticResource DdAccent}"
                                             BorderThickness="0"
                                             Minimum="0" Maximum="100" Value="0"/>
                                <!-- Row 3: action buttons (right-aligned) -->
                                <StackPanel Name="UpdateButtonsRow" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,9,0,0">
                                    <Button Name="UpdateSecondaryButton"
                                            Visibility="Collapsed"
                                            Click="OnUpdateSecondaryClicked"
                                            Style="{StaticResource GlassSubtleBtn}"
                                            Margin="0,0,6,0" Content="Cancel"/>
                                    <Button Name="UpdatePrimaryButton"
                                            Click="OnUpdatePrimaryClicked"
                                            Style="{StaticResource GlassPillBtn}"
                                            Content="Install"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Settings section -->
                        <TextBlock Text="Settings" FontSize="{StaticResource DdFsXs}" FontWeight="SemiBold"
                                   Foreground="{StaticResource DdFg3}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Launch on startup" FontSize="{StaticResource DdFsBase}"
                                           Foreground="{StaticResource DdFg1}"/>
                                <TextBlock Text="Start minimized to system tray" FontSize="{StaticResource DdFsXs}"
                                           Foreground="{StaticResource DdFg3}" Margin="0,1,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" Name="StartOnWindowsStartupToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Style="{StaticResource GlassDivider}"/>

                        <!-- Star repo -->
                        <Button Click="OnStarRepoClicked"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                materialDesign:ButtonAssist.CornerRadius="{StaticResource DdRadiusMd}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="8,6" Foreground="{StaticResource DdFg3}"
                                Height="Auto" MinHeight="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭐" FontSize="{StaticResource DdFsLg}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Star on GitHub" FontSize="{StaticResource DdFsBase}"
                                               Foreground="{StaticResource DdFg1}"/>
                                    <TextBlock Text="Show your support!" FontSize="{StaticResource DdFsXs}"
                                               Foreground="{StaticResource DdFg3}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Border Style="{StaticResource GlassDivider}"/>

                        <!-- Help / GitHub -->
                        <Button Click="OnOpenGitHubClicked"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                materialDesign:ButtonAssist.CornerRadius="{StaticResource DdRadiusMd}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="8,6" Foreground="{StaticResource DdFg3}"
                                Height="Auto" MinHeight="0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Github" Width="15" Height="15"
                                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Report an issue" FontSize="{StaticResource DdFsBase}"
                                               Foreground="{StaticResource DdFg1}"/>
                                    <TextBlock Text="Open GitHub Issues" FontSize="{StaticResource DdFsXs}"
                                               Foreground="{StaticResource DdFg3}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!-- Version footer — always rendered, updated once the
                             check completes ("· Up to date" / "· vX.Y.Z available") -->
                        <TextBlock Name="VersionFooter" Text="Version 1.1.0"
                                   FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                   Margin="0,12,0,0" HorizontalAlignment="Center"
                                   Opacity="0.6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ==================== CONTENT ==================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========== PRESETS OVERLAY ========== -->
                <Grid Name="PresetsOverlay" Grid.ColumnSpan="2"
                      Visibility="Collapsed" Panel.ZIndex="100"
                      Background="{StaticResource DdBgOverlay}"
                      MouseLeftButtonDown="PresetsOverlay_Dismiss">
                    <Border CornerRadius="{StaticResource DdRadiusXl}" Background="{StaticResource DdBgGlass}"
                            BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
                            Padding="20,20,20,16" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Effect="{StaticResource DdShadow3}">
                        <StackPanel>
                            <TextBlock Text="Start from a preset" FontSize="{StaticResource DdFsMd}" FontWeight="SemiBold"
                                       Foreground="{StaticResource DdFg1}" Margin="0,0,0,4"/>
                            <TextBlock Text="Adds a new profile to the sidebar. Tweak afterwards in the keyboard view."
                                       FontSize="{StaticResource DdFsXs}" Foreground="{StaticResource DdFg3}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>
                            <ItemsControl Name="PresetsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="OnPresetItemClicked" Tag="{Binding Key}"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Padding="12,10" Margin="0,0,0,6"
                                                Background="{StaticResource DdSurfaceRow}"
                                                BorderBrush="{StaticResource DdBorderThin}" BorderThickness="1"
                                                Foreground="{StaticResource DdFg1}"
                                                Height="Auto" MinHeight="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Grid.Column="0" Kind="{Binding Icon}" Width="20" Height="20"
                                                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                                                         Foreground="{StaticResource DdAccent}"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource DdFsBase}"
                                                               FontWeight="SemiBold" Foreground="{StaticResource DdFg1}"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="{StaticResource DdFsXs}"
                                                               Foreground="{StaticResource DdFg3}" Margin="0,2,0,0"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Cancel" Click="PresetsCancel_Click"
                                    Style="{StaticResource GlassSubtleBtn}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== PROFILE DETAILS OVERLAY ========== -->
                <!-- Process triggers + notes for the selected profile. Lives
                     here (not inline in the toolbar) because they take real
                     vertical space and would compete with the keyboard view. -->
                <Grid Name="ProfileDetailsOverlay" Grid.ColumnSpan="2"
                      Visibility="Collapsed" Panel.ZIndex="100"
                      Background="{StaticResource DdBgOverlay}"
                      MouseLeftButtonDown="ProfileDetailsOverlay_Dismiss">
                    <Border CornerRadius="{StaticResource DdRadiusXl}" Background="{StaticResource DdBgGlass}"
                            BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
                            Padding="22,20,22,16" Width="460"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Effect="{StaticResource DdShadow3}">
                        <StackPanel>
                            <TextBlock Name="ProfileDetailsTitle" Text="Profile details"
                                       FontSize="{StaticResource DdFsMd}" FontWeight="SemiBold"
                                       Foreground="{StaticResource DdFg1}" Margin="0,0,0,14"/>

                            <TextBlock Text="PROCESS TRIGGERS" FontSize="{StaticResource DdFsXs}"
                                       FontWeight="SemiBold" Foreground="{StaticResource DdFg3}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Switch to this profile when one of these apps is focused."
                                       FontSize="{StaticResource DdFsXs}"
                                       Foreground="{StaticResource DdFg3}" Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            <ItemsControl Name="ProcessTriggersPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GlassChip}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Converter={StaticResource ProcessToImageConverter}}"
                                                       Width="14" Height="14" Margin="0,0,4,0"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="{Binding Converter={StaticResource ProcessTriggerToNameConverter}}"
                                                           FontSize="{StaticResource DdFsSm}" Foreground="{StaticResource DdFg1}"
                                                           VerticalAlignment="Center"/>
                                                <Button Click="OnRemoveTriggerClicked" Tag="{Binding}"
                                                        Style="{StaticResource MaterialDesignToolButton}"
                                                        Width="16" Height="16" Margin="6,0,0,0" Padding="0"
                                                        Foreground="{StaticResource DdFg3}">
                                                    <materialDesign:PackIcon Kind="Close" Width="11" Height="11"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Click="OnAddProcessTriggerClicked"
                                    Style="{StaticResource GlassSubtleBtn}"
                                    HorizontalAlignment="Left" Margin="0,4,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="13" Height="13"
                                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Add app" VerticalAlignment="Center" FontSize="{StaticResource DdFsSm}"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="NOTES" FontSize="{StaticResource DdFsXs}"
                                       FontWeight="SemiBold" Foreground="{StaticResource DdFg3}"
                                       Margin="0,0,0,8"/>
                            <TextBox Name="ProfileNoteTextBox" LostFocus="OnProfileNoteChanged"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="{StaticResource DdFsBase}" AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="60" MaxHeight="160" VerticalScrollBarVisibility="Auto"
                                     Foreground="{StaticResource DdFg1}"/>

                            <Button Content="Close" Click="ProfileDetailsClose_Click"
                                    Style="{StaticResource GlassSubtleBtn}"
                                    HorizontalAlignment="Right" Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== RENAME OVERLAY ========== -->
                <Grid Name="RenameOverlay" Grid.ColumnSpan="2"
                      Visibility="Collapsed" Panel.ZIndex="100"
                      Background="{StaticResource DdBgOverlay}"
                      MouseLeftButtonDown="RenameOverlay_Dismiss">
                    <Border CornerRadius="{StaticResource DdRadiusXl}" Background="{StaticResource DdBgGlass}"
                            BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
                            Padding="24" Width="340" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Effect="{StaticResource DdShadow3}">
                        <StackPanel>
                            <TextBlock Text="Rename Profile" FontSize="{StaticResource DdFsMd}" FontWeight="SemiBold"
                                       Foreground="{StaticResource DdFg1}" Margin="0,0,0,14"/>
                            <TextBox Name="RenameTextBox"
                                     materialDesign:HintAssist.Hint="Profile name"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="{StaticResource DdFsMd}" Foreground="{StaticResource DdFg1}"
                                     KeyDown="RenameTextBox_KeyDown"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Cancel" Click="RenameCancel_Click"
                                        Style="{StaticResource GlassSubtleBtn}" Margin="0,0,8,0"/>
                                <Button Content="Rename" Click="RenameConfirm_Click"
                                        Style="{StaticResource GlassPillBtn}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== INFO / WARNING OVERLAY ==========
                     Themed replacement for Windows MessageBox. Reused for
                     the hotkey hint and the duplicate-binding warning so
                     both fit the DrunkDeer design tokens (DdBgGlass /
                     DdAccent / DdFontSans). Populated from code-behind
                     via ShowInfoOverlay(title, body, accent). -->
                <Grid Name="InfoOverlay" Grid.ColumnSpan="2"
                      Visibility="Collapsed" Panel.ZIndex="100"
                      Background="{StaticResource DdBgOverlay}"
                      MouseLeftButtonDown="InfoOverlay_Backdrop">
                    <Border CornerRadius="{StaticResource DdRadiusXl}" Background="{StaticResource DdBgGlass}"
                            BorderBrush="{StaticResource DdBorderMed}" BorderThickness="1"
                            Padding="22,20,22,16" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Effect="{StaticResource DdShadow3}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Name="InfoOverlayIcon" Kind="LightbulbOnOutline"
                                                         Width="18" Height="18"
                                                         Foreground="{StaticResource DdAccent}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Name="InfoOverlayTitle" Text=""
                                           FontSize="{StaticResource DdFsMd}" FontWeight="SemiBold"
                                           FontFamily="{StaticResource DdFontSans}"
                                           Foreground="{StaticResource DdFg1}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Name="InfoOverlayBody" Text=""
                                       FontSize="{StaticResource DdFsBase}"
                                       FontFamily="{StaticResource DdFontSans}"
                                       Foreground="{StaticResource DdFg2}"
                                       LineHeight="20" TextWrapping="Wrap" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Name="InfoOverlayDontShowAgain"
                                          Visibility="Collapsed"
                                          Content="Don't show this again"
                                          Foreground="{StaticResource DdFg3}"
                                          FontFamily="{StaticResource DdFontSans}"
                                          FontSize="{StaticResource DdFsSm}"
                                          VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Name="InfoOverlayCancelBtn" Content="Cancel"
                                            Visibility="Collapsed"
                                            Click="InfoOverlay_Cancel"
                                            Style="{StaticResource GlassSubtleBtn}" Margin="0,0,8,0"/>
                                    <Button Name="InfoOverlayPrimaryBtn" Content="Got it"
                                            Click="InfoOverlay_Primary"
                                            Style="{StaticResource GlassPillBtn}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== SIDEBAR ========== -->
                <Border Grid.Column="0" Name="SidebarBorder" Background="{StaticResource DdBgSidebar}"
                        BorderBrush="{StaticResource DdBorderThin}" BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,12">
                    <Grid ClipToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="6,8,6,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Click="OnImportButtonClicked"
                                    Style="{StaticResource GlassSidebarBtn}" Margin="0,0,3,0"
                                    ToolTip="Import a profile .json from the DrunkDeer web driver or drag-and-drop one onto the window.">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,5,0"
                                                             Foreground="{StaticResource DdInfo}"/>
                                    <TextBlock Text="Import" FontSize="{StaticResource DdFsBase}"
                                               FontFamily="{StaticResource DdFontSans}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Click="OnPresetsButtonClicked"
                                    Style="{StaticResource GlassSidebarBtn}" Margin="3,0,0,0"
                                    ToolTip="Start from a built-in profile (FPS, Valorant, Typing, Default).">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Star" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,5,0"
                                                             Foreground="{StaticResource DdAccent}"/>
                                    <TextBlock Text="Presets" FontSize="{StaticResource DdFsBase}"
                                               FontFamily="{StaticResource DdFontSans}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Border Grid.Column="2" Background="Transparent" Cursor="Help"
                                    VerticalAlignment="Center" Margin="2,0,4,0"
                                    Tag="How to create and export a profile from the DrunkDeer web driver.|https://github.com/svumo/DrunkDeer-Control/blob/main/Importing-Profiles.md"
                                    MouseLeftButtonDown="OnImportHelpClicked"
                                    MouseEnter="HelpIcon_MouseEnter" MouseLeave="HelpIcon_MouseLeave">
                                <materialDesign:PackIcon Kind="HelpCircleOutline" Width="14" Height="14"
                                                         Foreground="{StaticResource DdFg3}" Opacity="0.7"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="16,10,8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PROFILES" FontSize="{StaticResource DdFsXs}" FontWeight="SemiBold"
                                       FontFamily="{StaticResource DdFontSans}"
                                       Foreground="{StaticResource DdFg3}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Click="OnRefreshProfilesClicked"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    Width="22" Height="22" Padding="0"
                                    Foreground="{StaticResource DdFg3}" Opacity="0.6"
                                    Tag="Re-apply active profile"
                                    MouseEnter="HelpIcon_MouseEnter" MouseLeave="HelpIcon_MouseLeave">
                                <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14"/>
                            </Button>
                        </Grid>

                        <ListBox Grid.Row="2" Name="ProfileListBox"
                                 SelectionChanged="OnProfileSelectionChanged"
                                 PreviewMouseLeftButtonDown="OnListBoxPreviewLeftClick"
                                 PreviewMouseRightButtonDown="OnListBoxPreviewRightClick"
                                 ItemContainerStyle="{StaticResource GlassListItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" BorderThickness="0"
                                 Margin="0,0,0,4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="{StaticResource DdFsMd}"
                                                       FontFamily="{StaticResource DdFontSans}"
                                                       Foreground="{StaticResource DdFg1}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Profile.Showname}" FontSize="{StaticResource DdFsXs}"
                                                       FontFamily="{StaticResource DdFontSans}"
                                                       Foreground="{StaticResource DdFg3}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Details (process triggers + notes). Always visible
                                             so the user can spot it without hovering — this is
                                             the way to reach per-profile triggers, which is a
                                             discoverability problem when buried in a hover state.
                                             Explicit Opacity overrides GlassIconBtn's default of 0
                                             (which is the hover-reveal pattern the pencil uses). -->
                                        <Button Grid.Column="1" Style="{StaticResource GlassIconBtn}"
                                                Tag="{Binding}" Click="OnSidebarOpenDetailsClicked"
                                                ToolTip="Process triggers, notes, direct keybind"
                                                Margin="6,0,0,0" Padding="4" Opacity="1"
                                                Foreground="{StaticResource DdFg2}">
                                            <materialDesign:PackIcon Kind="DotsHorizontal" Width="16" Height="16"/>
                                        </Button>

                                        <!-- Rename pencil (visible on hover) -->
                                        <Button Grid.Column="2" Style="{StaticResource GlassIconBtn}"
                                                Tag="{Binding}" Click="OnSidebarRenameClicked"
                                                ToolTip="Rename profile" Margin="2,0,0,0"
                                                Opacity="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver, Converter={StaticResource BoolToOpacityConverter}}"
                                                IsHitTestVisible="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}">
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="13" Height="13"/>
                                        </Button>

                                        <!-- Active indicator dot -->
                                        <Ellipse Grid.Column="3" Width="8" Height="8"
                                                 Fill="{StaticResource DdSuccess}"
                                                 VerticalAlignment="Center" Margin="6,0,2,0"
                                                 Visibility="{Binding IsActiveProfile, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBox.ContextMenu>
                                <ContextMenu Style="{StaticResource GlassContextMenu}">
                                    <MenuItem Header="Rename" Click="OnContextMenuRenameClicked"
                                              Style="{StaticResource GlassMenuItem}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14"
                                                                     Foreground="{StaticResource DdFg2}"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Delete" Click="OnContextMenuDeleteClicked"
                                              Style="{StaticResource GlassMenuItemDelete}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14"
                                                                     Foreground="{StaticResource DdDanger}"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>

                        <TextBlock Grid.Row="3" Name="SidebarVersionLabel" Text=""
                                   FontSize="{StaticResource DdFsXs}"
                                   FontFamily="{StaticResource DdFontSans}"
                                   Foreground="{StaticResource DdFg3}" Opacity="0.6"
                                   Margin="14,4,8,10" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- ========== DETAIL: top profile toolbar + keyboard view ========== -->
                <!-- Background: solid DdBgBase. The keyboard view's gap areas
                     are transparent, so anything translucent here lets the
                     desktop bleed through every empty pixel of the canvas. -->
                <Border Grid.Column="1" CornerRadius="0,0,12,0" ClipToBounds="True" Background="{StaticResource DdBgBase}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Profile toolbar (Row 0). Only visible when a profile
                             is selected. Single-row layout: name + subtitle |
                             Quick Switch | Default | Direct Keybind | More |
                             Activate / Export / Delete. Process triggers and
                             notes live behind the More icon (popup) so they
                             don't compete for height. -->
                        <Border Grid.Row="0" Name="ProfileFooter" Visibility="Collapsed"
                                Background="{StaticResource DdBgSidebar}"
                                BorderBrush="{StaticResource DdBorderThin}" BorderThickness="0,0,0,1"
                                Padding="20,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Profile name + subtitle + hotkey chip.
                                     Hotkey lives here (under the name) rather
                                     than in the right action cluster because
                                     it's a per-profile binding users actively
                                     search for — keeping it next to the name
                                     makes it discoverable without scanning. -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                                    <TextBlock Name="DetailProfileName" Text=""
                                               FontSize="{StaticResource DdFsLg}" FontWeight="SemiBold"
                                               Foreground="{StaticResource DdFg1}"/>
                                    <TextBlock Name="DetailProfileSubtitle" Text=""
                                               FontSize="{StaticResource DdFsXs}"
                                               Foreground="{StaticResource DdFg3}" Margin="0,1,0,0"/>
                                    <Border Name="DirectKeybindChip"
                                            CornerRadius="{StaticResource DdRadiusSm}"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource DdAccent}" BorderThickness="1"
                                            Padding="9,4" Margin="0,6,0,0"
                                            HorizontalAlignment="Left"
                                            Cursor="Hand" MouseLeftButtonDown="OnDirectKeybindBadgeClicked"
                                            ToolTip="Click to record a hotkey that switches directly to this profile. Press Escape to clear.">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="KeyboardOutline"
                                                                     Width="14" Height="14"
                                                                     Foreground="{StaticResource DdAccent}"
                                                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                                            <TextBlock Text="Hotkey:" FontSize="{StaticResource DdFsSm}"
                                                       FontFamily="{StaticResource DdFontSans}"
                                                       Foreground="{StaticResource DdFg3}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Name="DirectKeybindLabel" Text="Click to set"
                                                       FontSize="{StaticResource DdFsSm}"
                                                       FontFamily="{StaticResource DdFontMono}"
                                                       Foreground="{StaticResource DdFg1}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Right cluster: Activate, then compact chip
                                     toggles for automation, then the icon
                                     buttons. Chips read as labels you can click;
                                     purple when on, outline when off. -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Name="ActivateButton" Content="Activate" Click="OnActivateProfileClicked"
                                            Style="{StaticResource GlassPillBtn}" Margin="0,0,10,0"
                                            ToolTip="Push this profile to the keyboard."/>

                                    <ToggleButton Name="DefaultProfileToggle" Content="Default"
                                                  Checked="OnDefaultProfileChanged" Unchecked="OnDefaultProfileChanged"
                                                  Style="{StaticResource DdChipToggle}" Margin="0,0,6,0"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Switch to this profile when no process trigger matches."/>
                                    <Button Click="OnExportProfileClicked"
                                            Style="{StaticResource MaterialDesignToolButton}"
                                            Padding="4" Foreground="{StaticResource DdFg2}"
                                            ToolTip="Export this profile to a .json file you can share or re-import.">
                                        <materialDesign:PackIcon Kind="Download" Width="16" Height="16"/>
                                    </Button>
                                    <Button Click="OnDeleteProfileClicked"
                                            Style="{StaticResource MaterialDesignToolButton}"
                                            Padding="4" Foreground="{StaticResource DdDanger}">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Top-level Keyboard / Lighting nav strip. Both views
                             live as children of PerfViewHost below and are
                             toggled by Visibility — keeps canvas/keystroke-
                             listener/firmware-banner state alive on switch. -->
                        <Border Grid.Row="1" Name="TopTabStrip"
                                Background="{StaticResource DdBgBase}"
                                BorderBrush="{StaticResource DdBorderThin}" BorderThickness="0,0,0,1"
                                Padding="20,8"
                                MinHeight="44">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="TopTabKeyboardBtn"
                                        Content="Keyboard"
                                        Click="OnTopTabKeyboardClicked"
                                        Padding="18,8"
                                        Margin="0,0,6,0"
                                        FontFamily="{StaticResource DdFontSans}"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource DdFg1}"
                                        Background="{StaticResource DdAccent}"
                                        BorderBrush="{StaticResource DdAccent}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        AutomationProperties.Name="Show keyboard editor"/>
                                <Button x:Name="TopTabLightingBtn"
                                        Content="Lighting"
                                        Click="OnTopTabLightingClicked"
                                        Padding="18,8"
                                        FontFamily="{StaticResource DdFontSans}"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource DdFg2}"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource DdBorderThin}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        AutomationProperties.Name="Show RGB lighting editor"/>
                            </StackPanel>
                        </Border>

                        <!-- Host for both KeyboardPerformanceView and LightingView.
                             Built in code-behind so each can receive the
                             KeyboardManager + ProfileManager via DI. Visibility
                             toggling preserves canvas/listener/banner state. -->
                        <Grid Grid.Row="2" Name="PerfViewHost"/>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
