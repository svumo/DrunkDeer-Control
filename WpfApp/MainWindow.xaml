<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp.Components"
        mc:Ignorable="d"
        Title="DrunkDeer Control"
        MinHeight="580" MinWidth="920"
        Height="660" Width="1060"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded" StateChanged="Window_StateChanged"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True">

    <Window.Resources>
        <local:ProcessTriggerToNameConverter x:Key="ProcessTriggerToNameConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
    </Window.Resources>

    <!-- Outer border = the glass pane -->
    <Border CornerRadius="12" BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
            Background="{StaticResource GlassBg}" ClipToBounds="True"
            Name="OuterBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ==================== TITLE BAR ==================== -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBg}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/deer_1f98c.ico" Width="18" Height="18" Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="DRUNKDEER CONTROL" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextW2}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Active profile pill -->
                    <Border Grid.Column="2" CornerRadius="10" Padding="10,3"
                            Background="{StaticResource RowBg}" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Name="ActiveProfileDot" Margin="0,0,7,0"
                                     VerticalAlignment="Center" Fill="{StaticResource GrayDot}"/>
                            <TextBlock Name="ActiveProfileText" Text="No profile active"
                                       FontSize="11" Foreground="{StaticResource TextW2}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Connection pill -->
                    <Border Grid.Column="3" CornerRadius="10" Padding="10,3"
                            Background="{StaticResource RowBg}" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Name="ConnectionDot" Margin="0,0,7,0"
                                     VerticalAlignment="Center" Fill="{StaticResource GrayDot}"/>
                            <TextBlock Name="KeyboardStatusText" Text="No keyboard"
                                       FontSize="11" Foreground="{StaticResource TextW2}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Options button + popup -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">

                        <Popup Name="OptionsPopup" Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True" PopupAnimation="Fade"
                               PlacementTarget="{Binding ElementName=OptionsButton}"
                               HorizontalOffset="-222" VerticalOffset="6">
                            <Border Background="#F2181824"
                                    BorderBrush="{StaticResource BorderMedium}"
                                    BorderThickness="1" CornerRadius="12"
                                    Padding="18,16" Width="260">
                                <StackPanel>
                                    <!-- Settings section -->
                                    <TextBlock Text="Settings" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextW3}" Margin="0,0,0,12"/>

                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Launch on startup" FontSize="12.5"
                                                       Foreground="{StaticResource TextW}"/>
                                            <TextBlock Text="Start minimized to system tray" FontSize="10.5"
                                                       Foreground="{StaticResource TextW3}" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Name="StartOnWindowsStartupToggle"
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Border Style="{StaticResource GlassDivider}"/>

                                    <!-- Keybinds section -->
                                    <TextBlock Text="Keybinds" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextW3}" Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border CornerRadius="6" Background="{StaticResource RowBg}"
                                                BorderBrush="{StaticResource BorderThin}" BorderThickness="1"
                                                Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center"
                                                Cursor="Hand" MouseLeftButtonDown="OnKeybindBadgeClicked"
                                                ToolTip="Click to record a new keybind">
                                            <TextBlock Name="QuickSwitchKeybindLabel" Text="Ctrl+End" FontSize="10.5"
                                                       Foreground="{StaticResource TextW2}"
                                                       FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="Cycle quick-switch profiles"
                                                   FontSize="11.5" Foreground="{StaticResource TextW3}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <Border Style="{StaticResource GlassDivider}"/>

                                    <!-- Help / GitHub -->
                                    <Button Click="OnOpenGitHubClicked"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="0,6" Foreground="{StaticResource TextW3}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Github" Width="15" Height="15"
                                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Report an issue" FontSize="12"
                                                           Foreground="{StaticResource TextW}"/>
                                                <TextBlock Text="Open GitHub Issues" FontSize="10"
                                                           Foreground="{StaticResource TextW3}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button Name="OptionsButton" Click="OptionsButton_Click"
                                Style="{StaticResource MaterialDesignToolButton}"
                                Width="28" Height="28" Padding="0"
                                Foreground="{StaticResource TextW3}"
                                ToolTip="Settings &amp; Keybinds">
                            <materialDesign:PackIcon Kind="Tune" Width="15" Height="15"/>
                        </Button>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Click="MinimizeButton_Click" Style="{StaticResource MaterialDesignToolButton}"
                                Width="28" Height="28" Padding="0" Foreground="{StaticResource TextW3}">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button Click="CloseButton_Click" Style="{StaticResource MaterialDesignToolButton}"
                                Width="28" Height="28" Padding="0" Foreground="{StaticResource TextW3}" Margin="4,0,0,0">
                            <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== CONTENT ==================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========== RENAME OVERLAY ========== -->
                <Grid Name="RenameOverlay" Grid.ColumnSpan="2"
                      Visibility="Collapsed" Panel.ZIndex="100"
                      Background="#80000000">
                    <Border CornerRadius="12" Background="#F2181824"
                            BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
                            Padding="24" Width="340" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Rename Profile" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextW}" Margin="0,0,0,14"/>
                            <TextBox Name="RenameTextBox"
                                     materialDesign:HintAssist.Hint="Profile name"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="13" Foreground="{StaticResource TextW}"
                                     KeyDown="RenameTextBox_KeyDown"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Cancel" Click="RenameCancel_Click"
                                        Style="{StaticResource GlassSubtleBtn}" Margin="0,0,8,0"/>
                                <Button Content="Rename" Click="RenameConfirm_Click"
                                        Style="{StaticResource GlassPillBtn}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== SIDEBAR ========== -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                        BorderBrush="{StaticResource BorderThin}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Click="OnImportButtonClicked"
                                Style="{StaticResource GlassSidebarBtn}" Margin="6,8,6,2">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="15" Height="15"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                                         Foreground="{StaticResource AccentSoft}"/>
                                <TextBlock Text="Import Profile" FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Row="1" Text="Profiles" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextW3}" Margin="18,10,0,6"/>

                        <ListBox Grid.Row="2" Name="ProfileListBox"
                                 SelectionChanged="OnProfileSelectionChanged"
                                 PreviewMouseRightButtonDown="OnListBoxPreviewRightClick"
                                 ItemContainerStyle="{StaticResource GlassListItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" BorderThickness="0"
                                 Margin="0,0,0,4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       Foreground="{StaticResource TextW}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Profile.Showname}" FontSize="10.5"
                                                       Foreground="{StaticResource TextW3}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                        </StackPanel>

                                        <!-- Rename pencil (visible on hover) -->
                                        <Button Grid.Column="1" Style="{StaticResource GlassIconBtn}"
                                                Tag="{Binding}" Click="OnSidebarRenameClicked"
                                                ToolTip="Rename profile" Margin="2,0,0,0"
                                                Opacity="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver, Converter={StaticResource BoolToOpacityConverter}}">
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="13" Height="13"/>
                                        </Button>

                                        <!-- Active indicator dot -->
                                        <Ellipse Grid.Column="2" Width="7" Height="7"
                                                 Fill="{StaticResource GreenDot}"
                                                 VerticalAlignment="Center" Margin="6,0,2,0"
                                                 Visibility="{Binding IsActiveProfile, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBox.ContextMenu>
                                <ContextMenu Style="{StaticResource GlassContextMenu}">
                                    <MenuItem Header="Rename" Click="OnContextMenuRenameClicked"
                                              Style="{StaticResource GlassMenuItem}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14"
                                                                     Foreground="{StaticResource TextW2}"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Delete" Click="OnContextMenuDeleteClicked"
                                              Style="{StaticResource GlassMenuItemDelete}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14"
                                                                     Foreground="{StaticResource RedSoft}"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- ========== DETAIL ========== -->
                <Grid Grid.Column="1">

                    <!-- Empty state -->
                    <StackPanel Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Resources/deer_1f98c.ico" Width="40" Height="40"
                               HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Select a profile" FontSize="15" Foreground="{StaticResource TextW3}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Choose from the sidebar to view settings" FontSize="11.5"
                                   Foreground="{StaticResource TextW3}" HorizontalAlignment="Center"
                                   Margin="0,4,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Detail content -->
                    <ScrollViewer Name="DetailScrollViewer" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,20,24,14">

                            <!-- Profile header -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Name="DetailProfileName" Text="" FontSize="20" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextW}"/>
                                    <TextBlock Name="DetailProfileSubtitle" Text="" FontSize="11.5"
                                               Foreground="{StaticResource TextW3}" Margin="0,3,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Name="ActivateButton" Content="Activate" Click="OnActivateProfileClicked"
                                            Style="{StaticResource GlassPillBtn}" Margin="0,0,6,0"
                                            ToolTip="Push this profile to the keyboard"/>
                                    <Button Click="OnDeleteProfileClicked"
                                            Style="{StaticResource MaterialDesignToolButton}"
                                            Padding="6" ToolTip="Delete profile" Foreground="{StaticResource RedSoft}">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="17" Height="17"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Two column -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Actuation -->
                                <Border Grid.Column="0" Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <TextBlock Text="Actuation" FontSize="11" Foreground="{StaticResource TextW3}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Kind="HelpCircleOutline" Width="13" Height="13"
                                                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                                                     Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                     IsHitTestVisible="True" Cursor="Help"
                                                                     ToolTip="Shows the actuation point range for all keys in this profile. Configure actuation settings in the DrunkDeer web driver, then re-import."/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Range" FontSize="12"
                                                       Foreground="{StaticResource TextW3}" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Name="ActuationRangeText"
                                                       Text="--" FontSize="12" Foreground="{StaticResource TextW}"
                                                       HorizontalAlignment="Right"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Rapid Trigger" FontSize="12"
                                                       Foreground="{StaticResource TextW3}" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Name="RtpStatusText"
                                                       Text="--" FontSize="12" Foreground="{StaticResource TextW}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Remap -->
                                <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <TextBlock Text="Key Remap" FontSize="11" Foreground="{StaticResource TextW3}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Kind="HelpCircleOutline" Width="13" Height="13"
                                                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                                                     Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                     IsHitTestVisible="True" Cursor="Help"
                                                                     ToolTip="Link a key remap file exported from the DrunkDeer web driver to override key assignments for this profile. Export remaps separately from the web driver."/>
                                        </StackPanel>
                                        <TextBlock Name="RemapStatusText" Text="None" FontSize="12"
                                                   Foreground="{StaticResource TextW}" Margin="0,0,0,12"/>
                                        <Button Content="Import" Click="OnImportRemapButtonClicked"
                                                Style="{StaticResource GlassSubtleBtn}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Automation -->
                            <Border Style="{StaticResource GlassCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <TextBlock Text="Automation" FontSize="11" Foreground="{StaticResource TextW3}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <materialDesign:PackIcon Kind="HelpCircleOutline" Width="13" Height="13"
                                                                 VerticalAlignment="Center" Margin="6,0,0,0"
                                                                 Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                 IsHitTestVisible="True" Cursor="Help"
                                                                 ToolTip="Configure automatic profile switching — by hotkey rotation, app focus, or as a fallback default."/>
                                    </StackPanel>

                                    <!-- Quick Switch -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Quick Switch" FontSize="13" Foreground="{StaticResource TextW}"
                                                           VerticalAlignment="Center"/>
                                                <materialDesign:PackIcon Kind="HelpCircleOutline" Width="12" Height="12"
                                                                         VerticalAlignment="Center" Margin="6,0,0,0"
                                                                         Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                         IsHitTestVisible="True" Cursor="Help"
                                                                         ToolTip="Include this profile in the quick-switch rotation. Use the global hotkey to cycle through all Quick Switch enabled profiles in order."/>
                                            </StackPanel>
                                            <TextBlock Text="Ctrl+End cycle rotation" FontSize="10.5"
                                                       Foreground="{StaticResource TextW3}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Name="QuickSwitchToggle"
                                                      Checked="OnQuickSwitchChanged" Unchecked="OnQuickSwitchChanged"
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>

                                    <Border Style="{StaticResource GlassDivider}"/>

                                    <!-- Direct Switch Keybind -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Direct Keybind" FontSize="13" Foreground="{StaticResource TextW}"
                                                           VerticalAlignment="Center"/>
                                                <materialDesign:PackIcon Kind="HelpCircleOutline" Width="12" Height="12"
                                                                         VerticalAlignment="Center" Margin="6,0,0,0"
                                                                         Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                         IsHitTestVisible="True" Cursor="Help"
                                                                         ToolTip="A hotkey that jumps directly to this profile from anywhere. Click the badge to record. Note: the Fn key is hardware-only and cannot be used here — try Alt+1, Ctrl+Alt+2, etc."/>
                                            </StackPanel>
                                            <TextBlock Text="Jump straight to this profile" FontSize="10.5"
                                                       Foreground="{StaticResource TextW3}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource RowBg}"
                                                BorderBrush="{StaticResource BorderThin}" BorderThickness="1"
                                                Padding="8,4" VerticalAlignment="Center"
                                                Cursor="Hand" MouseLeftButtonDown="OnDirectKeybindBadgeClicked"
                                                ToolTip="Click to record. Press Escape to clear.">
                                            <TextBlock Name="DirectKeybindLabel" Text="None" FontSize="10.5"
                                                       Foreground="{StaticResource TextW3}" FontFamily="Consolas"/>
                                        </Border>
                                    </Grid>

                                    <Border Style="{StaticResource GlassDivider}"/>

                                    <!-- Default -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Default Profile" FontSize="13" Foreground="{StaticResource TextW}"
                                                           VerticalAlignment="Center"/>
                                                <materialDesign:PackIcon Kind="HelpCircleOutline" Width="12" Height="12"
                                                                         VerticalAlignment="Center" Margin="6,0,0,0"
                                                                         Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                         IsHitTestVisible="True" Cursor="Help"
                                                                         ToolTip="Automatically activate this profile when no process trigger matches the focused window. Only one profile can be the default at a time."/>
                                            </StackPanel>
                                            <TextBlock Text="Fallback when no trigger matches" FontSize="10.5"
                                                       Foreground="{StaticResource TextW3}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Name="DefaultProfileToggle"
                                                      Checked="OnDefaultProfileChanged" Unchecked="OnDefaultProfileChanged"
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>

                                    <Border Style="{StaticResource GlassDivider}"/>

                                    <!-- Process Triggers -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Process Triggers" FontSize="13" Foreground="{StaticResource TextW}"
                                                   VerticalAlignment="Center"/>
                                        <materialDesign:PackIcon Kind="HelpCircleOutline" Width="12" Height="12"
                                                                 VerticalAlignment="Center" Margin="6,0,0,0"
                                                                 Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                 IsHitTestVisible="True" Cursor="Help"
                                                                 ToolTip="Automatically switch to this profile when one of these applications is focused. Add apps using the + Add button below."/>
                                    </StackPanel>

                                    <ItemsControl Name="ProcessTriggersPanel">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource GlassChip}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Converter={StaticResource ProcessTriggerToNameConverter}}"
                                                                   FontSize="11.5" Foreground="{StaticResource TextW}"
                                                                   VerticalAlignment="Center"/>
                                                        <Button Click="OnRemoveTriggerClicked" Tag="{Binding}"
                                                                Style="{StaticResource MaterialDesignToolButton}"
                                                                Width="16" Height="16" Margin="6,0,0,0" Padding="0"
                                                                Foreground="{StaticResource TextW3}">
                                                            <materialDesign:PackIcon Kind="Close" Width="11" Height="11"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Click="OnAddProcessTriggerClicked"
                                            Style="{StaticResource GlassSubtleBtn}"
                                            HorizontalAlignment="Left" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="13" Height="13"
                                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="Add" VerticalAlignment="Center" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Notes -->
                            <Border Style="{StaticResource GlassCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="Notes" FontSize="11" Foreground="{StaticResource TextW3}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <materialDesign:PackIcon Kind="HelpCircleOutline" Width="12" Height="12"
                                                                 VerticalAlignment="Center" Margin="6,0,0,0"
                                                                 Foreground="{StaticResource TextW3}" Opacity="0.6"
                                                                 IsHitTestVisible="True" Cursor="Help"
                                                                 ToolTip="A personal note for this profile — jot down what settings it uses, what game it's for, or anything else worth remembering."/>
                                    </StackPanel>
                                    <TextBox Name="ProfileNoteTextBox" LostFocus="OnProfileNoteChanged"
                                             materialDesign:HintAssist.Hint="Add a note about this profile…"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             FontSize="12" AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="60" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                             Foreground="{StaticResource TextW}"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
